<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:IndoorNav.Controls"
             xmlns:models="clr-namespace:IndoorNav.Models"
             xmlns:conv="clr-namespace:IndoorNav.Converters"
             xmlns:vm="clr-namespace:IndoorNav.ViewModels"
             x:Class="IndoorNav.MainPage"
             x:DataType="vm:MainViewModel"
             Title="Навигация"
             BackgroundColor="#F1F5F9">

    <ContentPage.Resources>
        <conv:NullToBoolConverter x:Key="NullToBoolConverter" />
        <conv:NullToBoolInvertConverter x:Key="NullToBoolInvertConverter" />
        <conv:BoolToColorConverter x:Key="BoolToColorConverter" />
        <conv:StringNotEmptyConverter x:Key="StringNotEmptyConverter" />
    </ContentPage.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{OnIdiom Phone=0, Default=218}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════
             SIDEBAR  (deep navy)
             ═══════════════════════════════════════ -->
        <Grid Grid.Column="0" BackgroundColor="#0F172A"
              RowDefinitions="Auto,Auto,*,Auto"
              IsVisible="{OnIdiom Phone=False, Default=True}">

            <!-- Logo -->
            <VerticalStackLayout Grid.Row="0" Padding="20,24,20,16" Spacing="2">
                <Label Text="IndoorNav"
                       FontSize="18" FontAttributes="Bold" TextColor="White" />
                <Label Text="Навигация по зданиям"
                       FontSize="11" TextColor="#475569" />
            </VerticalStackLayout>

            <!-- Buildings -->
            <VerticalStackLayout Grid.Row="1" Padding="10,0,10,0">
                <Label Text="ЗДАНИЕ" FontSize="10" CharacterSpacing="1.5"
                       TextColor="#334155" Margin="8,0,0,8" />
                <CollectionView ItemsSource="{Binding Buildings}"
                                SelectedItem="{Binding SelectedBuilding, Mode=TwoWay}"
                                SelectionMode="Single" HeightRequest="88">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Building">
                            <Border Padding="12,9" Margin="0,2"
                                    StrokeShape="RoundRectangle 8" StrokeThickness="0"
                                    BackgroundColor="Transparent">
                                <Label Text="{Binding Name}" FontSize="14" TextColor="#94A3B8" />
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroupList>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="Normal">
                                                <VisualState.Setters>
                                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                                </VisualState.Setters>
                                            </VisualState>
                                            <VisualState x:Name="Selected">
                                                <VisualState.Setters>
                                                    <Setter Property="BackgroundColor" Value="#1D4ED8" />
                                                </VisualState.Setters>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateGroupList>
                                </VisualStateManager.VisualStateGroups>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <!-- Floors -->
            <VerticalStackLayout Grid.Row="2" Padding="10,14,10,8">
                <Label Text="ЭТАЖ" FontSize="10" CharacterSpacing="1.5"
                       TextColor="#334155" Margin="8,0,0,8" />
                <CollectionView ItemsSource="{Binding Floors}"
                                SelectedItem="{Binding SelectedFloor, Mode=TwoWay}"
                                SelectionMode="Single">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Floor">
                            <Border Padding="12,10" Margin="0,2"
                                    StrokeShape="RoundRectangle 8" StrokeThickness="0"
                                    BackgroundColor="Transparent">
                                <Label Text="{Binding Name}" FontSize="14" TextColor="#94A3B8" />
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroupList>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="Normal">
                                                <VisualState.Setters>
                                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                                </VisualState.Setters>
                                            </VisualState>
                                            <VisualState x:Name="Selected">
                                                <VisualState.Setters>
                                                    <Setter Property="BackgroundColor" Value="#1D4ED8" />
                                                </VisualState.Setters>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateGroupList>
                                </VisualStateManager.VisualStateGroups>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <!-- Admin button + user info -->
            <Border Grid.Row="3" Padding="10,8,10,20" BackgroundColor="Transparent" StrokeThickness="0">
                <VerticalStackLayout Spacing="6">
                    <!-- User name label -->
                    <Label Text="{Binding CurrentUserName}"
                           FontSize="12" TextColor="#64748B"
                           HorizontalTextAlignment="Center"
                           Margin="0,0,0,2" />
                    <!-- Admin button (only for admin users) -->
                    <Button Text="🔑 Сменить пароль"
                            Command="{Binding ChangePasswordCommand}"
                            IsVisible="{Binding IsAdminUser}"
                            BackgroundColor="#1E293B" TextColor="#94A3B8"
                            FontSize="13" CornerRadius="8" HeightRequest="38" />
                    <Button Text="⚙ Администратор"
                            Command="{Binding GoToAdminCommand}"
                            IsVisible="{Binding IsAdminUser}"
                            BackgroundColor="#1E293B" TextColor="#64748B"
                            FontSize="13" CornerRadius="8" HeightRequest="38" />
                    <!-- Change password button (only for students) -->
                    <Button Text="🔑 Изменить пароль"
                            Command="{Binding ChangePasswordCommand}"
                            IsVisible="{Binding IsStudentUser}"
                            BackgroundColor="#1E293B" TextColor="#FCD34D"
                            FontSize="13" CornerRadius="8" HeightRequest="38" />
                    <!-- Logout button -->
                    <Button Text="Выйти"
                            Command="{Binding LogoutCommand}"
                            BackgroundColor="#1E293B" TextColor="#EF4444"
                            FontSize="13" CornerRadius="8" HeightRequest="38" />
                </VerticalStackLayout>
            </Border>

        </Grid>

        <!-- ═══════════════════════════════════════
             MAIN AREA
             ═══════════════════════════════════════ -->
        <Grid Grid.Column="1" Padding="{OnIdiom Phone='0', Default='14'}" RowDefinitions="Auto,*,Auto">

            <!-- ═══ PHONE TOP BAR (hidden on desktop) ═══ -->
            <Grid Grid.Row="0" BackgroundColor="#0F172A" Padding="10,8,10,8"
                  ColumnDefinitions="*,*,Auto" ColumnSpacing="6"
                  IsVisible="{OnIdiom Phone=True, Default=False}">
                <Picker Grid.Column="0"
                        ItemsSource="{Binding Buildings}"
                        SelectedItem="{Binding SelectedBuilding, Mode=TwoWay}"
                        ItemDisplayBinding="{Binding Name}"
                        Title="Здание" TitleColor="#475569"
                        TextColor="White" BackgroundColor="#1E293B" />
                <Picker Grid.Column="1"
                        ItemsSource="{Binding Floors}"
                        SelectedItem="{Binding SelectedFloor, Mode=TwoWay}"
                        ItemDisplayBinding="{Binding Name}"
                        Title="Этаж" TitleColor="#475569"
                        TextColor="White" BackgroundColor="#1E293B" />
                <Button Grid.Column="2" Text="⚙"
                        Command="{Binding GoToAdminCommand}"
                        IsVisible="{Binding IsAdminUser}"
                        BackgroundColor="#1E293B" TextColor="#64748B"
                        WidthRequest="44" HeightRequest="44"
                        CornerRadius="8" Padding="0" />
            </Grid>

            <!-- Canvas card -->
            <Border Grid.Row="1"
                    StrokeShape="RoundRectangle 14"
                    Stroke="#E2E8F0" StrokeThickness="1"
                    BackgroundColor="White" Padding="0">
                <Grid>

                    <!-- Placeholder removed: building loads automatically on startup -->

                    <!-- Map -->
                    <controls:SvgView x:Name="MainCanvas"
                                      FloorSvgPath="{Binding SelectedFloor.SvgPath}"
                                      CurrentFloorNumber="{Binding SelectedFloor.Number}"
                                      Nodes="{Binding NodesOnCurrentFloor}"
                                      Edges="{Binding EdgesOnCurrentFloor}"
                                      RouteNodes="{Binding RouteNodesOnFloor}"
                                      RouteNodeBreaks="{Binding RouteBreaksOnFloor}"
                                      HighlightBoundaryNode="{Binding EndNode}"
                                      HighlightStartNode="{Binding StartNode}"
                                      ShowFireExtinguishers="{Binding ShowFireExtinguishers}"
                                      QrAnchorNodeIds="{Binding QrAnchorNodeIds}"
                                      BlockedNodeIds="{Binding BlockedNodeIds}"
                                      ShowRouteWaypoints="{Binding IsBlockingMode}"
                                      ShowGraph="True"
                                      HorizontalOptions="Fill" VerticalOptions="Fill" />

                    <!-- Loading overlay -->
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="12"
                                         IsVisible="{Binding IsLoading}">
                        <ActivityIndicator IsRunning="{Binding IsLoading}"
                                           Color="#2563EB" WidthRequest="36" HeightRequest="36"
                                           HorizontalOptions="Center" />
                        <Label Text="Загрузка планов..."
                               FontSize="13" TextColor="#94A3B8" HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <!-- Error overlay -->
                    <Border HorizontalOptions="Center" VerticalOptions="Center"
                            Padding="20,16" Margin="20"
                            StrokeShape="RoundRectangle 12"
                            BackgroundColor="#FEF2F2" Stroke="#FECACA"
                            IsVisible="{Binding HasLoadError}">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="⚠ Ошибка загрузки" FontSize="14" FontAttributes="Bold"
                                   TextColor="#DC2626" HorizontalOptions="Center" />
                            <Label Text="{Binding LoadError}" FontSize="12" TextColor="#7F1D1D"
                                   HorizontalTextAlignment="Center" LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Emergency banner (top overlay) -->
                    <Border HorizontalOptions="Fill" VerticalOptions="Start"
                            BackgroundColor="#DC2626" Padding="14,10"
                            StrokeThickness="0"
                            IsVisible="{Binding IsEmergencyBannerVisible}"
                            ZIndex="20">
                        <Label Text="{Binding EmergencyMessage}"
                               TextColor="White" FontAttributes="Bold"
                               FontSize="13" HorizontalTextAlignment="Center" />
                    </Border>

                    <!-- Blocking-mode hint banner — replaces the emergency banner in the same slot -->
                    <Border HorizontalOptions="Fill" VerticalOptions="Start"
                            BackgroundColor="#DC2626" Padding="14,10"
                            StrokeThickness="0"
                            IsVisible="{Binding IsBlockingMode}"
                            ZIndex="20">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <Label Grid.Column="0"
                                   Text="⛔ Нажмите на точку маршрута, где проход закрыт"
                                   FontSize="13" TextColor="White" FontAttributes="Bold"
                                   VerticalOptions="Center" LineBreakMode="WordWrap" />
                            <Button Grid.Column="1"
                                    Text="Отмена"
                                    Command="{Binding CancelBlockingModeCommand}"
                                    BackgroundColor="#991B1B" TextColor="#FCA5A5"
                                    FontSize="12" HeightRequest="34" CornerRadius="8" Padding="10,0" />
                        </Grid>
                    </Border>

                    <!-- Confirmation overlay: shown after user taps a route node -->
                    <Border HorizontalOptions="Center" VerticalOptions="Center"
                            BackgroundColor="White" Padding="24,20"
                            StrokeShape="RoundRectangle 16"
                            Stroke="#DC2626" StrokeThickness="2"
                            IsVisible="{Binding IsBlockPending}"
                            ZIndex="50"
                            MaximumWidthRequest="360">
                        <VerticalStackLayout Spacing="14">
                            <Label Text="⛔ Подтверждение"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="#DC2626" HorizontalOptions="Center" />
                            <Label FontSize="14" TextColor="#334155"
                                   HorizontalTextAlignment="Center" LineBreakMode="WordWrap">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="Проход в точке " />
                                        <Span Text="{Binding PendingBlockNodeName}" FontAttributes="Bold" TextColor="#7F1D1D" />
                                        <Span Text=" недоступен?" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                            <Label Text="Маршрут будет перестроен в обход этой точки."
                                   FontSize="12" TextColor="#64748B"
                                   HorizontalTextAlignment="Center" LineBreakMode="WordWrap" />
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <Button Grid.Column="0"
                                        Text="✕ Выбрать другую"
                                        Command="{Binding CancelBlockNodeConfirmCommand}"
                                        BackgroundColor="#F1F5F9" TextColor="#334155"
                                        FontSize="13" HeightRequest="42" CornerRadius="10" />
                                <Button Grid.Column="1"
                                        Text="✓ Да, недоступно"
                                        Command="{Binding ConfirmBlockNodeCommand}"
                                        BackgroundColor="#DC2626" TextColor="White"
                                        FontSize="13" HeightRequest="42" CornerRadius="10" FontAttributes="Bold" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Подтверждение местоположения (автоопределено по расписанию) -->
                    <!-- No-route popup: all exits blocked in ЧС mode -->
                    <Border HorizontalOptions="Center" VerticalOptions="Center"
                            BackgroundColor="White" Padding="28,24"
                            StrokeShape="RoundRectangle 16"
                            Stroke="#DC2626" StrokeThickness="2"
                            IsVisible="{Binding ShowNoRoutePopup}"
                            ZIndex="60"
                            MaximumWidthRequest="340">
                        <VerticalStackLayout Spacing="16">
                            <Label Text="🚨 Выход недоступен"
                                   FontSize="17" FontAttributes="Bold"
                                   TextColor="#DC2626" HorizontalOptions="Center" />
                            <Label Text="Все возможные маршруты к выходу заблокированы."
                                   FontSize="14" TextColor="#334155"
                                   HorizontalTextAlignment="Center" LineBreakMode="WordWrap" />
                            <Button Text="ОК"
                                    Command="{Binding DismissNoRoutePopupCommand}"
                                    BackgroundColor="#DC2626" TextColor="White"
                                    FontSize="15" FontAttributes="Bold"
                                    HeightRequest="46" CornerRadius="10" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Подтверждение местоположения (автоопределено по расписанию) -->
                    <Border HorizontalOptions="Center" VerticalOptions="Center"
                            BackgroundColor="White" Padding="20,18"
                            StrokeShape="RoundRectangle 16"
                            Stroke="#DC2626" StrokeThickness="2"
                            IsVisible="{Binding ShowEmergencyConfirmation}"
                            ZIndex="30"
                            MaximumWidthRequest="360">
                        <VerticalStackLayout Spacing="14">
                            <Label Text="⚠️ Чрезвычайная ситуация"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="#DC2626"
                                   HorizontalOptions="Center" />
                            <Label FontSize="14" TextColor="#334155"
                                   HorizontalTextAlignment="Center"
                                   LineBreakMode="WordWrap">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="Вы сейчас в " />
                                        <Span Text="{Binding EmergencyAutoLocationName}" FontAttributes="Bold" TextColor="#2563EB" />
                                        <Span Text="?" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                            <Label Text="Подтвердите своё местоположение или выберите другую точку."
                                   FontSize="12" TextColor="#64748B"
                                   HorizontalTextAlignment="Center"
                                   LineBreakMode="WordWrap" />
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <Button Grid.Column="0"
                                        Text="✖ Отмена"
                                        Command="{Binding CancelEmergencyConfirmationCommand}"
                                        BackgroundColor="#F1F5F9" TextColor="#475569"
                                        FontSize="14" HeightRequest="46" CornerRadius="10" />
                                <Button Grid.Column="1"
                                        Text="✔ Я здесь"
                                        Command="{Binding ConfirmEmergencyLocationCommand}"
                                        BackgroundColor="#DC2626" TextColor="White"
                                        FontAttributes="Bold"
                                        FontSize="14" HeightRequest="46" CornerRadius="10" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Breadcrumb pill (top-left overlay) -->
                    <Border HorizontalOptions="Start" VerticalOptions="Start"
                            Margin="12" Padding="12,6"
                            StrokeShape="RoundRectangle 20"
                            BackgroundColor="#CC0F172A"
                            StrokeThickness="0"
                            IsVisible="{Binding SelectedFloor, Converter={StaticResource NullToBoolConverter}}">
                        <HorizontalStackLayout Spacing="6">
                            <Label Text="{Binding SelectedBuilding.Name}"
                                   FontSize="12" FontAttributes="Bold"
                                   TextColor="White" VerticalOptions="Center" />
                            <Label Text="›" FontSize="14" TextColor="#64748B" VerticalOptions="Center" />
                            <Label Text="{Binding SelectedFloor.Name}"
                                   FontSize="12" TextColor="#94A3B8" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Node tap popup: dim backdrop -->
                    <BoxView Color="#66000000"
                             IsVisible="{Binding IsNodePopupOpen}">
                        <BoxView.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CloseNodePopupCommand}" />
                        </BoxView.GestureRecognizers>
                    </BoxView>

                    <!-- Node tap popup: modal card -->
                    <Border HorizontalOptions="Center" VerticalOptions="Center"
                            Padding="20,18" Margin="32"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="White"
                            Stroke="#E2E8F0" StrokeThickness="1"
                            IsVisible="{Binding IsNodePopupOpen}">
                        <Grid>
                            <VerticalStackLayout Spacing="14" MinimumWidthRequest="220">
                                <Label Text="{Binding TappedNodeName}"
                                       FontSize="15" FontAttributes="Bold" TextColor="#0F172A"
                                       HorizontalOptions="Center" />
                                <Label Text="{Binding TappedNodeTypeLabel}"
                                       FontSize="12" TextColor="#0F172A"
                                       HorizontalOptions="Center"
                                       IsVisible="{Binding TappedNodeTypeLabel, Converter={StaticResource StringNotEmptyConverter}}" />
                                <Label Text="{Binding TappedNodeCategory}"
                                       FontSize="12" TextColor="#2563EB"
                                       HorizontalOptions="Center"
                                       IsVisible="{Binding TappedNodeCategory, Converter={StaticResource StringNotEmptyConverter}}" />
                                <Label Text="{Binding TappedNodeInfo}"
                                       FontSize="12" TextColor="#64748B"
                                       HorizontalOptions="Center" />
                                <!-- Нормальный режим: две кнопки -->
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10"
                                      IsVisible="{Binding IsNormalMode}">
                                    <Button Grid.Column="0" Text="Отсюда"
                                            Command="{Binding SetTappedAsStartCommand}"
                                            BackgroundColor="#2B4EDB" TextColor="White"
                                            BorderWidth="0"
                                            FontSize="13" FontAttributes="Bold"
                                            CornerRadius="22" HeightRequest="44" />
                                    <Button Grid.Column="1" Text="Сюда"
                                            Command="{Binding SetTappedAsEndCommand}"
                                            BackgroundColor="#2B4EDB" TextColor="White"
                                            BorderWidth="0"
                                            FontSize="13" FontAttributes="Bold"
                                            CornerRadius="22" HeightRequest="44" />
                                </Grid>
                                <!-- Режим ЧС: только кнопка Отсюда на всю ширину -->
                                <Button Text="Отсюда"
                                        Command="{Binding SetTappedAsStartCommand}"
                                        IsVisible="{Binding IsEmergencyActive}"
                                        BackgroundColor="#DC2626" TextColor="White"
                                        BorderWidth="0"
                                        FontSize="13" FontAttributes="Bold"
                                        CornerRadius="22" HeightRequest="44" />
                            </VerticalStackLayout>
                            <!-- Close button top-right -->
                            <Border BackgroundColor="#E5E7EB"
                                    StrokeShape="RoundRectangle 12"
                                    StrokeThickness="0"
                                    WidthRequest="24" HeightRequest="24"
                                    HorizontalOptions="End" VerticalOptions="Start"
                                    Margin="0,-10,-10,0"
                                    Padding="0">
                                <Label Text="✕" FontSize="11" FontAttributes="Bold"
                                       TextColor="#6B7280"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding CloseNodePopupCommand}" />
                                </Border.GestureRecognizers>
                            </Border>
                        </Grid>
                    </Border>

                </Grid>
            </Border>

            <!-- ─── Bottom panel ─── -->
            <VerticalStackLayout Grid.Row="2" Spacing="8" Margin="{OnIdiom Phone='10,8,10,10', Default='0,10,0,0'}">

                <!-- Search input panels: hidden in ЧС-mode once route is built -->
                <VerticalStackLayout IsVisible="{Binding ShowSearchPanel}" Spacing="8">

                <!-- Route input bar (PHONE – vertical stack) -->
                <Border Padding="12,12"
                        IsVisible="{OnIdiom Phone=True, Default=False}"
                        StrokeShape="{OnIdiom Phone='RoundRectangle 0', Default='RoundRectangle 12'}"
                        BackgroundColor="White"
                        Stroke="#E2E8F0" StrokeThickness="{OnIdiom Phone=0, Default=1}">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="36,*,Auto" ColumnSpacing="8">
                            <Label Grid.Column="0" Text="ОТ" FontSize="10" CharacterSpacing="1.5"
                                   TextColor="#94A3B8" VerticalOptions="Center" />
                            <Border Grid.Column="1" Padding="12,12"
                                    StrokeShape="RoundRectangle 10" Stroke="#E2E8F0" BackgroundColor="#F8FAFC">
                                <Label Text="{Binding StartNodeDisplay}" FontSize="14" TextColor="#334155"
                                       LineBreakMode="TailTruncation" />
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding OpenStartPickerCommand}" />
                                </Border.GestureRecognizers>
                            </Border>
                            <!-- QR scan button -->
                            <Button Grid.Column="2"
                                    Text="📷"
                                    Command="{Binding ScanQrCommand}"
                                    BackgroundColor="#0E7490" TextColor="White"
                                    CornerRadius="10" WidthRequest="44" HeightRequest="44"
                                    Padding="0" FontSize="16"
                                    ToolTipProperties.Text="Отсканировать QR-код" />
                        </Grid>
                        <!-- ДО — скрыто в режиме ЧС -->
                        <Grid ColumnDefinitions="36,*" ColumnSpacing="8" IsVisible="{Binding IsNormalMode}">
                            <Label Grid.Column="0" Text="ДО" FontSize="10" CharacterSpacing="1.5"
                                   TextColor="#94A3B8" VerticalOptions="Center" />
                            <Border Grid.Column="1" Padding="12,12"
                                    StrokeShape="RoundRectangle 10" Stroke="#E2E8F0" BackgroundColor="#F8FAFC">
                                <Label Text="{Binding EndNodeDisplay}" FontSize="14" TextColor="#334155"
                                       LineBreakMode="TailTruncation" />
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding OpenEndPickerCommand}" />
                                </Border.GestureRecognizers>
                            </Border>
                        </Grid>
                        <!-- Обычные кнопки маршрута -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" IsVisible="{Binding IsNormalMode}">
                            <Button Grid.Column="0" Text="Построить маршрут"
                                    Command="{Binding BuildRouteCommand}"
                                    BackgroundColor="#2563EB" TextColor="White"
                                    FontSize="14" HeightRequest="48" CornerRadius="10" />
                            <Button Grid.Column="1" Text="✕"
                                    Command="{Binding ClearRouteCommand}"
                                    BackgroundColor="{Binding HasAnySelection, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#EF4444|#CBD5E1'}"
                                    TextColor="White" FontSize="15"
                                    WidthRequest="48" HeightRequest="48" CornerRadius="10" Padding="0" />
                        </Grid>
                        <!-- Кнопка эвакуации (только в режиме ЧС) -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" IsVisible="{Binding IsEmergencyActive}">
                            <Button Grid.Column="0" Text="🚨  До выхода"
                                    Command="{Binding BuildEmergencyRouteCommand}"
                                    BackgroundColor="#DC2626" TextColor="White"
                                    FontAttributes="Bold"
                                    FontSize="14" HeightRequest="48" CornerRadius="10" />
                            <Button Grid.Column="1" Text="✕"
                                    Command="{Binding ClearRouteCommand}"
                                    BackgroundColor="{Binding HasAnySelection, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#EF4444|#CBD5E1'}"
                                    TextColor="White" FontSize="15"
                                    WidthRequest="48" HeightRequest="48" CornerRadius="10" Padding="0" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Route input bar (DESKTOP – horizontal) -->
                <Border Padding="16,12"
                        IsVisible="{OnIdiom Phone=False, Default=True}"
                        StrokeShape="RoundRectangle 12"
                        BackgroundColor="White"
                        Stroke="#E2E8F0" StrokeThickness="1">
                    <Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="14">

                        <!-- Откуда field -->
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="ОТ" FontSize="10" CharacterSpacing="1.5" TextColor="#94A3B8" />
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                <Border Grid.Column="0" Padding="10,8"
                                        StrokeShape="RoundRectangle 8"
                                        Stroke="#E2E8F0" StrokeThickness="1"
                                        BackgroundColor="#F8FAFC">
                                    <Label Text="{Binding StartNodeDisplay}"
                                           FontSize="13" TextColor="#334155"
                                           LineBreakMode="TailTruncation" />
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding OpenStartPickerCommand}" />
                                    </Border.GestureRecognizers>
                                </Border>
                                <!-- QR-ссылка (только на десктопе) -->
                                <Button Grid.Column="1"
                                        Text="📷"
                                        Command="{Binding ScanQrCommand}"
                                        BackgroundColor="#0E7490" TextColor="White"
                                        CornerRadius="8" WidthRequest="36" HeightRequest="36"
                                        Padding="0" FontSize="15"
                                        ToolTipProperties.Text="Ввести QR-ссылку" />
                            </Grid>
                        </VerticalStackLayout>

                        <!-- Куда field — скрыто в режиме ЧС -->
                        <VerticalStackLayout Grid.Column="1" Spacing="4" IsVisible="{Binding IsNormalMode}">
                            <Label Text="ДО" FontSize="10" CharacterSpacing="1.5" TextColor="#94A3B8" />
                            <Border Padding="10,8"
                                    StrokeShape="RoundRectangle 8"
                                    Stroke="#E2E8F0" StrokeThickness="1"
                                    BackgroundColor="#F8FAFC">
                                <Label Text="{Binding EndNodeDisplay}"
                                       FontSize="13" TextColor="#334155"
                                       LineBreakMode="TailTruncation" />
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding OpenEndPickerCommand}" />
                                </Border.GestureRecognizers>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Подсказка местоположения в режиме ЧС (вместо ДО) -->
                        <VerticalStackLayout Grid.Column="1" Spacing="4" IsVisible="{Binding IsEmergencyActive}">
                            <Label Text="ЧС — выберите точку выхода" FontSize="10" CharacterSpacing="1.5" TextColor="#DC2626" />
                            <Border Padding="10,8"
                                    StrokeShape="RoundRectangle 8"
                                    Stroke="#FCA5A5" StrokeThickness="1"
                                    BackgroundColor="#FEF2F2">
                                <Label Text="Автоматически — ближайший выход"
                                       FontSize="13" TextColor="#991B1B"
                                       LineBreakMode="TailTruncation" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Build + Clear buttons + blocked-route button -->
                        <VerticalStackLayout Grid.Column="2" VerticalOptions="End" Spacing="6">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <!-- Обычная кнопка маршрута -->
                                <Button Grid.Column="0"
                                        Text="Построить маршрут"
                                        Command="{Binding BuildRouteCommand}"
                                        IsVisible="{Binding IsNormalMode}"
                                        BackgroundColor="#2563EB" TextColor="White"
                                        FontSize="13" Padding="18,9" CornerRadius="8" />
                                <!-- Кнопка эвакуации в режиме ЧС -->
                                <Button Grid.Column="0"
                                        Text="🚨 До выхода"
                                        Command="{Binding BuildEmergencyRouteCommand}"
                                        IsVisible="{Binding IsEmergencyActive}"
                                        BackgroundColor="#DC2626" TextColor="White"
                                        FontAttributes="Bold"
                                        FontSize="13" Padding="18,9" CornerRadius="8" />
                                <Button Grid.Column="1"
                                        Text="✕"
                                        Command="{Binding ClearRouteCommand}"
                                        BackgroundColor="{Binding HasAnySelection, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#EF4444|#CBD5E1'}"
                                        TextColor="White"
                                        FontSize="14" WidthRequest="38" HeightRequest="38"
                                        CornerRadius="8" Padding="0" />
                            </Grid>
                        </VerticalStackLayout>

                    </Grid>
                </Border>

                </VerticalStackLayout>

                <!-- Route step card -->
                <Border Padding="0"
                        StrokeShape="RoundRectangle 10"
                        BackgroundColor="White"
                        Stroke="#E2E8F0" StrokeThickness="1"
                        IsVisible="{Binding HasRoute}">
                    <Grid IsClippedToBounds="True" Padding="16,14">
                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">

                        <!-- Строка: кнопка назад (стрелка) слева + этаж + точки справа -->
                        <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,*,Auto" VerticalOptions="Center" ColumnSpacing="8">
                            <!-- Кнопка назад в виде стрелки слева: всегда видима при HasRoute -->
                            <Border Grid.Column="0"
                                    BackgroundColor="#F1F5F9"
                                    StrokeShape="RoundRectangle 15"
                                    StrokeThickness="0"
                                    WidthRequest="30" HeightRequest="30"
                                    HorizontalOptions="Start" VerticalOptions="Center">
                                <Label Text="‹"
                                       FontSize="20" FontAttributes="Bold"
                                       TextColor="#475569"
                                       HorizontalOptions="Center" VerticalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center"
                                       Margin="0,0,0,2" />
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPrevStepClicked" />
                                </Border.GestureRecognizers>
                            </Border>
                            <!-- Этаж текущего шага -->
                            <Label Grid.Column="1"
                                   Text="{Binding CurrentStepFloorLabel}"
                                   FontSize="13" FontAttributes="Bold"
                                   TextColor="#475569" VerticalOptions="Center" />
                            <!-- Точки-индикаторы справа -->
                            <HorizontalStackLayout Grid.Column="3"
                                                   HorizontalOptions="End"
                                                   VerticalOptions="Center"
                                                   Spacing="6"
                                                   IsVisible="{Binding IsMultiStepRoute}"
                                                   BindableLayout.ItemsSource="{Binding RouteStepDots}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="vm:RouteDotVm">
                                        <BoxView WidthRequest="8" HeightRequest="8"
                                                 CornerRadius="4"
                                                 Color="{Binding IsActive, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#2563EB|#CBD5E1'}" />
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </HorizontalStackLayout>
                        </Grid>

                        <!-- Icon + instruction text (animated on step change) -->
                        <Grid x:Name="StepTextContent" Grid.Row="1" ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Label Grid.Column="0"
                                   Text="{Binding CurrentStepIcon}"
                                   FontSize="26" VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   Text="{Binding CurrentStepText}"
                                   FontSize="15" TextColor="#0F172A"
                                   FontAttributes="Bold"
                                   LineBreakMode="WordWrap"
                                   VerticalOptions="Center" />
                        </Grid>

                        <!-- Кнопки навигации: Далее / Завершить + компактная кнопка "⛔ Недоступно" -->
                        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Button Grid.Column="0" Text="Далее"
                                    Clicked="OnNextStepClicked"
                                    IsVisible="{Binding HasNextStep}"
                                    BackgroundColor="#2563EB" TextColor="White"
                                    FontSize="14" HeightRequest="44" CornerRadius="8" />
                            <Button Grid.Column="0" Text="Завершить"
                                    Command="{Binding ClearRouteCommand}"
                                    IsVisible="{Binding IsLastStep}"
                                    BackgroundColor="#16A34A" TextColor="White"
                                    FontSize="14" HeightRequest="44" CornerRadius="8" />
                            <!-- ⛔ Недоступно: компактная, рядом с кнопкой навигации, только при HasEmergencyRoute -->
                            <Button Grid.Column="1"
                                    Text="⛔"
                                    Command="{Binding MarkRouteBlockedCommand}"
                                    IsVisible="{Binding HasEmergencyRoute}"
                                    BackgroundColor="#7F1D1D" TextColor="#FCA5A5"
                                    FontSize="14" WidthRequest="44" HeightRequest="44"
                                    CornerRadius="8" Padding="0"
                                    ToolTipProperties.Text="Отметить проход недоступным" />
                        </Grid>

                    </Grid>
                    </Grid>
                </Border>

            </VerticalStackLayout>

            <!-- ─── Node picker overlay ─── -->

            <!-- Backdrop: semi-transparent, tap to close -->
            <BoxView Grid.RowSpan="3"
                     Color="#55000000"
                     IsVisible="{Binding IsPickerOpen}">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ClosePickerCommand}" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <!-- Popup card -->
            <Border Grid.Row="1" VerticalOptions="End"
                    Padding="0"
                    StrokeShape="RoundRectangle 14"
                    BackgroundColor="White"
                    Stroke="#E2E8F0" StrokeThickness="1"
                    IsVisible="{Binding IsPickerOpen}">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">

                    <!-- Header -->
                    <Grid Grid.Row="0" Padding="16,10,8,10" ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="{Binding PickerTitle}"
                               FontSize="14" FontAttributes="Bold"
                               TextColor="#0F172A" VerticalOptions="Center" />
                        <Button Grid.Column="1"
                                Text="✕"
                                Command="{Binding ClosePickerCommand}"
                                BackgroundColor="Transparent" TextColor="#64748B"
                                FontSize="15" HeightRequest="34" WidthRequest="34"
                                Padding="0" />
                    </Grid>

                    <!-- Divider -->
                    <BoxView Grid.Row="1" BackgroundColor="#E2E8F0" HeightRequest="1" />

                    <!-- Search bar -->
                    <Border Grid.Row="2" Padding="12,8"
                            BackgroundColor="#F8FAFC" StrokeThickness="0">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                            <Label Grid.Column="0" Text="🔍"
                                   FontSize="14" VerticalOptions="Center"
                                   TextColor="#94A3B8" />
                            <Entry Grid.Column="1"
                                   Text="{Binding PickerSearchText, Mode=TwoWay}"
                                   Placeholder="Поиск аудитории..."
                                   PlaceholderColor="#94A3B8"
                                   FontSize="13" TextColor="#1E293B"
                                   BackgroundColor="Transparent"
                                   ClearButtonVisibility="WhileEditing"
                                   ReturnType="Search" />
                        </Grid>
                    </Border>

                    <!-- Divider -->
                    <BoxView Grid.Row="3" BackgroundColor="#E2E8F0" HeightRequest="1" />

                    <!-- Collapsible floor groups -->
                    <ScrollView Grid.Row="4" MaximumHeightRequest="280">
                        <VerticalStackLayout Spacing="0"
                                             BindableLayout.ItemsSource="{Binding NodesByFloor}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:FloorNodeGroup">
                                    <VerticalStackLayout Spacing="0">

                                        <!-- Floor header row — tap to expand / collapse -->
                                        <Border Padding="16,10,16,10"
                                                BackgroundColor="#F8FAFC"
                                                StrokeThickness="0">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <Label Grid.Column="0"
                                                       Text="{Binding FloorName}"
                                                       FontSize="11" FontAttributes="Bold"
                                                       CharacterSpacing="1.2"
                                                       TextColor="#64748B"
                                                       VerticalOptions="Center" />
                                                <Label Grid.Column="1"
                                                       Text="{Binding ChevronText}"
                                                       FontSize="11" TextColor="#94A3B8"
                                                       VerticalOptions="Center" />
                                            </Grid>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding ToggleExpandCommand}" />
                                            </Border.GestureRecognizers>
                                        </Border>

                                        <!-- Node items — shown only when floor is expanded -->
                                        <VerticalStackLayout Spacing="0"
                                                             BindableLayout.ItemsSource="{Binding VisibleNodes}">
                                            <BindableLayout.ItemTemplate>
                                                <DataTemplate x:DataType="{x:Null}">
                                                    <Border Padding="22,11,16,11"
                                                            BackgroundColor="Transparent"
                                                            StrokeThickness="0">
                                                        <Label Text="{Binding DisplayName}"
                                                               FontSize="14" TextColor="#1E293B" />
                                                        <Border.GestureRecognizers>
                                                            <TapGestureRecognizer
                                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectPickerNodeCommand}"
                                                                CommandParameter="{Binding .}" />
                                                        </Border.GestureRecognizers>
                                                    </Border>
                                                </DataTemplate>
                                            </BindableLayout.ItemTemplate>
                                        </VerticalStackLayout>

                                        <!-- Thin separator between floors -->
                                        <BoxView BackgroundColor="#F1F5F9" HeightRequest="1" />

                                    </VerticalStackLayout>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </ScrollView>

                </Grid>
            </Border>

        </Grid>

    </Grid>
</ContentPage>
