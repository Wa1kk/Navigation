<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IndoorNav.Pages.QrScanPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Black">

    <Grid>
        <!-- Camera view added here programmatically on Android / iOS -->
        <ContentView x:Name="CameraHolder" HorizontalOptions="Fill" VerticalOptions="Fill" />

        <!-- Viewfinder frame overlay -->
        <Border WidthRequest="240" HeightRequest="240"
                HorizontalOptions="Center" VerticalOptions="Center"
                BackgroundColor="Transparent"
                Stroke="#00BCD4" StrokeThickness="3"
                StrokeShape="RoundRectangle 14" />

        <!-- Hint -->
        <Label Text="Наведите камеру на QR-код"
               TextColor="#CCCCCC" FontSize="15"
               HorizontalOptions="Center" VerticalOptions="Center"
               Margin="0,170,0,0" />

        <!-- Close button -->
        <Button Text="✕"
                Clicked="OnCloseClicked"
                HorizontalOptions="Start" VerticalOptions="Start"
                Margin="16,44,0,0"
                BackgroundColor="#80000000" TextColor="White"
                CornerRadius="22" WidthRequest="44" HeightRequest="44"
                FontSize="18" Padding="0" />
    </Grid>
</ContentPage>
