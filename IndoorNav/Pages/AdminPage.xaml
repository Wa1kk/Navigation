<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:IndoorNav.Controls"
             xmlns:models="clr-namespace:IndoorNav.Models"
             xmlns:conv="clr-namespace:IndoorNav.Converters"
             xmlns:vm="clr-namespace:IndoorNav.ViewModels"
             x:Class="IndoorNav.Pages.AdminPage"
             x:Name="AdminRoot"
             x:DataType="vm:AdminViewModel"
             Title="Редактор графа"
             BackgroundColor="#F1F5F9">

    <ContentPage.Resources>
        <conv:BoolToColorConverter      x:Key="BoolToColorConverter" />
        <conv:NullToBoolConverter       x:Key="NullToBoolConverter" />
        <conv:InverseBoolConverter      x:Key="InverseBoolConverter" />
        <conv:StringNotEmptyConverter   x:Key="StringNotEmptyConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- ═══════════════════════════════════════
             TOP TAB BAR
             ═══════════════════════════════════════ -->
        <Grid Grid.Row="0" ColumnDefinitions="*,*" BackgroundColor="#0F172A" HeightRequest="48">
            <Button Grid.Column="0" Text="🗺  Карта"
                    Command="{Binding SwitchToMapCommand}"
                    BackgroundColor="{Binding IsMapMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#1E3A5F|Transparent'}"
                    TextColor="{Binding IsMapMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#475569'}"
                    FontSize="14" CornerRadius="0" BorderWidth="0" />
            <Button Grid.Column="1" Text="⚙  Управление"
                    Command="{Binding SwitchToManagementCommand}"
                    BackgroundColor="{Binding IsManagementMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#1E3A5F|Transparent'}"
                    TextColor="{Binding IsManagementMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#475569'}"
                    FontSize="14" CornerRadius="0" BorderWidth="0" />
        </Grid>

        <!-- ═══════════════════════════════════════
             MAP MODE  (Row 1)
             ═══════════════════════════════════════ -->
        <Grid Grid.Row="1" IsVisible="{Binding IsMapMode}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{OnIdiom Phone=0, Default=238}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════
             SIDEBAR  (deep navy)
             ═══════════════════════════════════════ -->
        <Grid Grid.Column="0" BackgroundColor="#0F172A"
              RowDefinitions="Auto,Auto,Auto,*"
              IsVisible="{OnIdiom Phone=False, Default=True}">

            <!-- Header -->
            <VerticalStackLayout Grid.Row="0" Padding="20,22,20,14" Spacing="2">
                <Label Text="Редактор графа"
                       FontSize="17" FontAttributes="Bold" TextColor="White" />
                <Label Text="Управление узлами и рёбрами"
                       FontSize="11" TextColor="#475569" />
            </VerticalStackLayout>

            <!-- Buildings -->
            <VerticalStackLayout Grid.Row="1" Padding="10,0,10,0">
                <Label Text="ЗДАНИЕ" FontSize="10" CharacterSpacing="1.5"
                       TextColor="#334155" Margin="8,0,0,8" />
                <CollectionView ItemsSource="{Binding Buildings}"
                                SelectedItem="{Binding SelectedBuilding, Mode=TwoWay}"
                                SelectionMode="Single" HeightRequest="90">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Building">
                            <Border Padding="12,9" Margin="0,2"
                                    StrokeShape="RoundRectangle 8" StrokeThickness="0"
                                    BackgroundColor="Transparent">
                                <Label Text="{Binding Name}" FontSize="14" TextColor="#94A3B8" />
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroupList>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="Normal">
                                                <VisualState.Setters>
                                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                                </VisualState.Setters>
                                            </VisualState>
                                            <VisualState x:Name="Selected">
                                                <VisualState.Setters>
                                                    <Setter Property="BackgroundColor" Value="#1D4ED8" />
                                                </VisualState.Setters>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateGroupList>
                                </VisualStateManager.VisualStateGroups>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <!-- Floors -->
            <VerticalStackLayout Grid.Row="2" Padding="10,12,10,0">
                <Label Text="ЭТАЖ" FontSize="10" CharacterSpacing="1.5"
                       TextColor="#334155" Margin="8,0,0,8" />
                <CollectionView ItemsSource="{Binding Floors}"
                                SelectedItem="{Binding SelectedFloor, Mode=TwoWay}"
                                SelectionMode="Single" HeightRequest="100">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Floor">
                            <Border Padding="12,9" Margin="0,2"
                                    StrokeShape="RoundRectangle 8" StrokeThickness="0"
                                    BackgroundColor="Transparent">
                                <Label Text="{Binding Name}" FontSize="14" TextColor="#94A3B8" />
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroupList>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="Normal">
                                                <VisualState.Setters>
                                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                                </VisualState.Setters>
                                            </VisualState>
                                            <VisualState x:Name="Selected">
                                                <VisualState.Setters>
                                                    <Setter Property="BackgroundColor" Value="#1D4ED8" />
                                                </VisualState.Setters>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateGroupList>
                                </VisualStateManager.VisualStateGroups>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <!-- Scrollable action buttons -->
            <ScrollView Grid.Row="3">
                <VerticalStackLayout Padding="10,6,10,20" Spacing="5">

                    <BoxView HeightRequest="1" BackgroundColor="#1E293B" Margin="4,6,4,10" />

                    <!-- ADD section -->
                    <Label Text="ДОБАВИТЬ" FontSize="10" CharacterSpacing="1.5"
                           TextColor="#334155" Margin="8,0,0,6" />

                    <Button Text="+ Аудитория"
                            Command="{Binding SetAddModeCommand}"
                            BackgroundColor="{Binding IsAddMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#2563EB|#1E293B'}"
                            TextColor="{Binding IsAddMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#94A3B8'}"
                            CornerRadius="8" HeightRequest="38" />

                    <Button Text="🪜 Лестница"
                            Command="{Binding SetStaircaseModeCommand}"
                            BackgroundColor="{Binding IsStaircaseMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#7C3AED|#1E293B'}"
                            TextColor="{Binding IsStaircaseMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#94A3B8'}"
                            CornerRadius="8" HeightRequest="38" />

                    <Button Text="🛗 Лифт"
                            Command="{Binding SetElevatorModeCommand}"
                            BackgroundColor="{Binding IsElevatorMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#0369A1|#1E293B'}"
                            TextColor="{Binding IsElevatorMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#94A3B8'}"
                            CornerRadius="8" HeightRequest="38" />

                    <Button Text="🚩 Выход"
                            Command="{Binding SetExitModeCommand}"
                            BackgroundColor="{Binding IsExitMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#15803D|#1E293B'}"
                            TextColor="{Binding IsExitMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#94A3B8'}"
                            CornerRadius="8" HeightRequest="38" />

                    <Button Text="🧯 Огнетушитель"
                            Command="{Binding SetFireExtinguisherModeCommand}"
                            BackgroundColor="{Binding IsFireExtinguisherMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#166534|#1E293B'}"
                            TextColor="{Binding IsFireExtinguisherMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#94A3B8'}"
                            CornerRadius="8" HeightRequest="38" />

                    <Button Text="� QR-якорь"
                            Command="{Binding SetQrAnchorModeCommand}"
                            BackgroundColor="{Binding IsQrAnchorMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#0E7490|#1E293B'}"
                            TextColor="{Binding IsQrAnchorMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#94A3B8'}"
                            CornerRadius="8" HeightRequest="38" />

                    <Button Text="�🚪 Выход"
                            Command="{Binding SetEvacuationExitModeCommand}"
                            BackgroundColor="{Binding IsEvacuationExitMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#7F1D1D|#1E293B'}"
                            TextColor="{Binding IsEvacuationExitMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#94A3B8'}"
                            CornerRadius="8" HeightRequest="38" />

                    <Button Text="••• Прочее"
                            Command="{Binding SetOtherModeCommand}"
                            BackgroundColor="{Binding IsOtherMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#B45309|#1E293B'}"
                            TextColor="{Binding IsOtherMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#94A3B8'}"
                            CornerRadius="8" HeightRequest="38" />

                    <Button Text="🛤 Коридор"
                            Command="{Binding SetCorridorModeCommand}"
                            BackgroundColor="{Binding IsCorridorMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#0F766E|#1E293B'}"
                            TextColor="{Binding IsCorridorMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#94A3B8'}"
                            CornerRadius="8" HeightRequest="38" />

                    <Button Text="✓ Завершить коридор"
                            Command="{Binding FinishCorridorCommand}"
                            IsVisible="{Binding IsCorridorMode}"
                            BackgroundColor="#064E3B" TextColor="#6EE7B7"
                            FontAttributes="Bold" CornerRadius="8" HeightRequest="34" />

                    <!-- ЧС section -->
                    <BoxView HeightRequest="1" BackgroundColor="#1E293B" Margin="4,6,4,10" />
                    <Label Text="РЕЖИМ ЧС" FontSize="10" CharacterSpacing="1.5"
                           TextColor="#334155" Margin="8,0,0,4" />

                    <!-- Per-building toggles -->
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding BuildingEmergencies}" Spacing="4">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="{x:Null}">
                                <Border Padding="10,8" BackgroundColor="#0F172A"
                                        StrokeShape="RoundRectangle 8" StrokeThickness="0">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <Label Grid.Column="0" Text="{Binding BuildingName}"
                                               FontSize="12" TextColor="#94A3B8"
                                               VerticalOptions="Center" />
                                        <Button Grid.Column="1"
                                                Text="⚠ Активировать"
                                                Command="{Binding ToggleCommand}"
                                                IsVisible="{Binding IsInactive}"
                                                BackgroundColor="#7F1D1D" TextColor="#FCA5A5"
                                                FontSize="11" FontAttributes="Bold"
                                                HeightRequest="34" CornerRadius="8" Padding="8,0" />
                                        <Button Grid.Column="1"
                                                Text="🔴 Деактивировать"
                                                Command="{Binding ToggleCommand}"
                                                IsVisible="{Binding IsActive}"
                                                BackgroundColor="#DC2626" TextColor="White"
                                                FontSize="11" FontAttributes="Bold"
                                                HeightRequest="34" CornerRadius="8" Padding="8,0" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <!-- All-buildings toggle -->
                    <Button Text="⚠ ВСЕ ЗДАНИЯ — АКТИВИРОВАТЬ"
                            Command="{Binding ToggleAllEmergencyCommand}"
                            IsVisible="{Binding IsEmergencyInactive}"
                            BackgroundColor="#7F1D1D" TextColor="#FCA5A5"
                            FontAttributes="Bold" CornerRadius="8" HeightRequest="38" Margin="0,2,0,0" />
                    <Button Text="🔴 ВСЕ ЗДАНИЯ — ДЕАКТИВИРОВАТЬ"
                            Command="{Binding ToggleAllEmergencyCommand}"
                            IsVisible="{Binding IsEmergencyActive}"
                            BackgroundColor="#DC2626" TextColor="White"
                            FontAttributes="Bold" CornerRadius="8" HeightRequest="38" Margin="0,2,0,0" />

                    <!-- EDIT section -->
                    <BoxView HeightRequest="1" BackgroundColor="#1E293B" Margin="4,6,4,10" />
                    <Label Text="РЕДАКТИРОВАТЬ" FontSize="10" CharacterSpacing="1.5"
                           TextColor="#334155" Margin="8,0,0,6" />

                    <Button Text="✏️ Переместить"
                            Command="{Binding SetMoveModeCommand}"
                            BackgroundColor="{Binding IsMoveMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#7C3AED|#1E293B'}"
                            TextColor="{Binding IsMoveMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#94A3B8'}"
                            CornerRadius="8" HeightRequest="38" />

                    <Button Text="✓ Подтвердить перемещение"
                            Command="{Binding ConfirmMoveCommand}"
                            IsVisible="{Binding IsMoveMode}"
                            BackgroundColor="#4C1D95" TextColor="#C4B5FD"
                            FontAttributes="Bold" CornerRadius="8" HeightRequest="34" />

                    <Button Text="↔ Соединить"
                            Command="{Binding SetConnectModeCommand}"
                            BackgroundColor="{Binding IsConnectMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#15803D|#1E293B'}"
                            TextColor="{Binding IsConnectMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#94A3B8'}"
                            CornerRadius="8" HeightRequest="38" />

                    <Button Text="✕ Разъединить"
                            Command="{Binding SetDisconnectModeCommand}"
                            BackgroundColor="{Binding IsDisconnectMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#C2410C|#1E293B'}"
                            TextColor="{Binding IsDisconnectMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#94A3B8'}"
                            CornerRadius="8" HeightRequest="38" />

                    <Button Text="✏ Переименовать"
                            Command="{Binding RenameSelectedCommand}"
                            BackgroundColor="#1E293B" TextColor="#94A3B8"
                            CornerRadius="8" HeightRequest="38" />

                    <Button Text="{Binding SelectedTransitionGroupIdText}"
                            Command="{Binding EditTransitionGroupIdCommand}"
                            IsVisible="{Binding SelectedNodeIsTransition}"
                            BackgroundColor="#1E293B" TextColor="#FCD34D"
                            CornerRadius="8" HeightRequest="38" />

                    <Button Text="📐 Граница"
                            Command="{Binding SetBoundaryModeCommand}"
                            BackgroundColor="{Binding IsBoundaryMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#D97706|#1E293B'}"
                            TextColor="{Binding IsBoundaryMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#94A3B8'}"
                            CornerRadius="8" HeightRequest="38" />

                    <Button Text="✓ Замкнуть"
                            Command="{Binding FinishBoundaryCommand}"
                            IsVisible="{Binding IsBoundaryMode}"
                            BackgroundColor="#92400E" TextColor="#FDE68A"
                            FontAttributes="Bold" CornerRadius="8" HeightRequest="34" />

                    <!-- Настройка вида выбранного узла -->
                    <Border Padding="10,8"
                            StrokeShape="RoundRectangle 8"
                            BackgroundColor="#162032"
                            Stroke="#1E3A5F" StrokeThickness="1"
                            IsVisible="{Binding SelectedNode, Converter={StaticResource NullToBoolConverter}}">
                        <VerticalStackLayout Spacing="7">
                            <Label Text="НАСТРОЙКА ТОЧКИ" FontSize="9" CharacterSpacing="1.5"
                                   TextColor="#475569" Margin="0,0,0,2" />

                            <!-- Скрыть точку -->
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                <Label Grid.Column="0" Text="Скрыть точку"
                                       FontSize="12" TextColor="#94A3B8" VerticalOptions="Center" />
                                <Switch Grid.Column="1"
                                        IsToggled="{Binding SelectedHidden, Mode=TwoWay}"
                                        OnColor="#EF4444" />
                            </Grid>

                            <!-- Скрыть подпись -->
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                <Label Grid.Column="0" Text="Скрыть подпись"
                                       FontSize="12" TextColor="#94A3B8" VerticalOptions="Center" />
                                <Switch Grid.Column="1"
                                        IsToggled="{Binding SelectedLabelHidden, Mode=TwoWay}"
                                        OnColor="#EF4444" />
                            </Grid>

                            <!-- Размер точки -->
                            <Label Text="{Binding SelectedNodeScale, StringFormat='Размер точки: {0:F1}×'}"
                                   FontSize="12" TextColor="#94A3B8" />
                            <Slider Minimum="0.4" Maximum="3.0" ThumbColor="#93C5FD"
                                    MinimumTrackColor="#2563EB" MaximumTrackColor="#334155"
                                    Value="{Binding SelectedNodeScale, Mode=TwoWay}" />

                            <!-- Размер текста -->
                            <Label Text="{Binding SelectedLabelScale, StringFormat='Размер текста: {0:F1}×'}"
                                   FontSize="12" TextColor="#94A3B8" />
                            <Slider Minimum="0.4" Maximum="3.0" ThumbColor="#93C5FD"
                                    MinimumTrackColor="#2563EB" MaximumTrackColor="#334155"
                                    Value="{Binding SelectedLabelScale, Mode=TwoWay}" />

                            <!-- Цвет точки -->
                            <Label Text="Цвет точки:" FontSize="12" TextColor="#94A3B8" />
                            <FlexLayout Wrap="Wrap" JustifyContent="Start">
                                <!-- auto/сброс -->
                                <Button Text="✕" WidthRequest="30" HeightRequest="30" CornerRadius="15" Padding="0" Margin="2"
                                        BackgroundColor="#334155" TextColor="White" FontSize="13"
                                        Command="{Binding SetNodeColorCommand}" CommandParameter="" />
                                <Button WidthRequest="30" HeightRequest="30" CornerRadius="15" Padding="0" Margin="2"
                                        BackgroundColor="#2196F3"
                                        Command="{Binding SetNodeColorCommand}" CommandParameter="2196F3" />
                                <Button WidthRequest="30" HeightRequest="30" CornerRadius="15" Padding="0" Margin="2"
                                        BackgroundColor="#4CAF50"
                                        Command="{Binding SetNodeColorCommand}" CommandParameter="4CAF50" />
                                <Button WidthRequest="30" HeightRequest="30" CornerRadius="15" Padding="0" Margin="2"
                                        BackgroundColor="#F44336"
                                        Command="{Binding SetNodeColorCommand}" CommandParameter="F44336" />
                                <Button WidthRequest="30" HeightRequest="30" CornerRadius="15" Padding="0" Margin="2"
                                        BackgroundColor="#FF9800"
                                        Command="{Binding SetNodeColorCommand}" CommandParameter="FF9800" />
                                <Button WidthRequest="30" HeightRequest="30" CornerRadius="15" Padding="0" Margin="2"
                                        BackgroundColor="#9C27B0"
                                        Command="{Binding SetNodeColorCommand}" CommandParameter="9C27B0" />
                                <Button WidthRequest="30" HeightRequest="30" CornerRadius="15" Padding="0" Margin="2"
                                        BackgroundColor="#E91E63"
                                        Command="{Binding SetNodeColorCommand}" CommandParameter="E91E63" />
                                <Button WidthRequest="30" HeightRequest="30" CornerRadius="15" Padding="0" Margin="2"
                                        BackgroundColor="#607D8B"
                                        Command="{Binding SetNodeColorCommand}" CommandParameter="607D8B" />
                                <Button WidthRequest="30" HeightRequest="30" CornerRadius="15" Padding="0" Margin="2"
                                        BackgroundColor="#009688"
                                        Command="{Binding SetNodeColorCommand}" CommandParameter="009688" />
                            </FlexLayout>

                            <!-- Сброс стиля -->
                            <Button Text="↺ Сброс стиля"
                                    Command="{Binding ResetNodeStyleCommand}"
                                    BackgroundColor="#1E293B" TextColor="#64748B"
                                    FontSize="12" HeightRequest="32" CornerRadius="6" />

                            <!-- Надпись на точке -->
                            <Button Text="{Binding SelectedInnerLabel, StringFormat='🔤 Надпись: {0}'}"
                                    Command="{Binding EditInnerLabelCommand}"
                                    BackgroundColor="#1E3A5F" TextColor="#93C5FD"
                                    FontSize="12" HeightRequest="32" CornerRadius="6" />

                            <!-- Ключевые слова поиска -->
                            <Button Text="{Binding SelectedSearchTags, StringFormat='🔍 Поиск: {0}'}"
                                    Command="{Binding EditSearchTagsCommand}"
                                    BackgroundColor="#1A2A40" TextColor="#64748B"
                                    LineBreakMode="TailTruncation"
                                    FontSize="12" HeightRequest="32" CornerRadius="6" />

                            <!-- Категория -->
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                <Button Grid.Column="0"
                                        Text="{Binding SelectedCategory, StringFormat='🏷️ Категория: {0}'}"
                                        Command="{Binding EditCategoryCommand}"
                                        BackgroundColor="#162032" TextColor="#7DD3FC"
                                        LineBreakMode="TailTruncation"
                                        FontSize="12" HeightRequest="32" CornerRadius="6" />
                                <Switch Grid.Column="1"
                                        IsToggled="{Binding SelectedCategoryHidden, Mode=TwoWay, Converter={StaticResource InverseBoolConverter}}"
                                        OnColor="#2563EB"
                                        VerticalOptions="Center" />
                            </Grid>

                            <!-- Тип: аудитория -->
                            <Button Text="{Binding SelectedNodeIsRoomText}"
                                    Command="{Binding ToggleIsRoomCommand}"
                                    BackgroundColor="{Binding SelectedNodeIsRoom, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#2563EB|#1E293B'}"
                                    TextColor="{Binding SelectedNodeIsRoom, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#64748B'}"
                                    FontSize="12" HeightRequest="32" CornerRadius="6" />

                            <!-- QR-код точки (видно только для QR-якорей) -->
                            <Button Text="📱 Показать QR-код"
                                    Command="{Binding ShowQrCodeCommand}"
                                    IsVisible="{Binding SelectedNodeIsQrAnchor}"
                                    BackgroundColor="#0E7490" TextColor="#99F6E4"
                                    FontSize="12" HeightRequest="32" CornerRadius="6" />

                            <!-- Удаление вершины границы -->
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6"
                                  IsVisible="{Binding HasBoundaryVertexSelected}">
                                <Label Grid.Column="0"
                                       Text="{Binding SelectedBoundaryVertexIndex, StringFormat='Вершина #{0}'}"
                                       FontSize="12" TextColor="#FB923C" VerticalOptions="Center" />
                                <Button Grid.Column="1" Text="✕ Удалить"
                                        Command="{Binding DeleteBoundaryVertexCommand}"
                                        BackgroundColor="#7F1D1D" TextColor="#FCA5A5"
                                        FontSize="11" HeightRequest="30" CornerRadius="6" Padding="8,0" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- MANAGE section -->
                    <BoxView HeightRequest="1" BackgroundColor="#1E293B" Margin="4,6,4,10" />
                    <Label Text="УПРАВЛЕНИЕ" FontSize="10" CharacterSpacing="1.5"
                           TextColor="#334155" Margin="8,0,0,6" />

                    <Button Text="🗑 Удалить  [Del]"
                            Command="{Binding DeleteSelectedCommand}"
                            BackgroundColor="#1E293B" TextColor="#F87171"
                            CornerRadius="8" HeightRequest="38" />

                    <Button Text="🗑 Удалить границу"
                            Command="{Binding ClearBoundaryCommand}"
                            BackgroundColor="#1E293B" TextColor="#F87171"
                            CornerRadius="8" HeightRequest="38" />

                    <Button Text="↩ Удалить последнюю"
                            Command="{Binding RemoveLastBoundaryCommand}"
                            BackgroundColor="#1E293B" TextColor="#FDA4AF"
                            CornerRadius="8" HeightRequest="38" />

                    <!-- CONTROL section -->
                    <BoxView HeightRequest="1" BackgroundColor="#1E293B" Margin="4,8,4,10" />

                    <Button Text="✕ Отменить"
                            Command="{Binding CancelActionCommand}"
                            BackgroundColor="#1E3A5F" TextColor="#93C5FD"
                            CornerRadius="8" HeightRequest="38" />

                    <Button Text="💾 Сохранить граф"
                            Command="{Binding SaveCommand}"
                            BackgroundColor="#2563EB" TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="8" HeightRequest="42" />

                </VerticalStackLayout>
            </ScrollView>

        </Grid>

        <!-- ═══════════════════════════════════════
             MAIN AREA
             ═══════════════════════════════════════ -->
        <Grid Grid.Column="1" Padding="{OnIdiom Phone='0', Default='14'}" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">

            <!-- ═══ PHONE TOP BAR (hidden on desktop) ═══ -->
            <Grid Grid.Row="0" BackgroundColor="#0F172A" Padding="10,8,10,8"
                  ColumnDefinitions="*,*" ColumnSpacing="6"
                  IsVisible="{OnIdiom Phone=True, Default=False}">
                <Picker Grid.Column="0"
                        ItemsSource="{Binding Buildings}"
                        SelectedItem="{Binding SelectedBuilding, Mode=TwoWay}"
                        ItemDisplayBinding="{Binding Name}"
                        Title="Здание" TitleColor="#475569"
                        TextColor="White" BackgroundColor="#1E293B" />
                <Picker Grid.Column="1"
                        ItemsSource="{Binding Floors}"
                        SelectedItem="{Binding SelectedFloor, Mode=TwoWay}"
                        ItemDisplayBinding="{Binding Name}"
                        Title="Этаж" TitleColor="#475569"
                        TextColor="White" BackgroundColor="#1E293B" />
            </Grid>

            <!-- Status bar -->
            <Border Grid.Row="1"
                    BackgroundColor="#FFF7ED"
                    StrokeShape="RoundRectangle 8"
                    Stroke="#FED7AA" StrokeThickness="1"
                    Padding="14,8" Margin="0,0,0,8">
                <Label Text="{Binding StatusText}" FontSize="13" TextColor="#92400E" />
            </Border>

            <!-- Selected node info badge -->
            <Border Grid.Row="3"
                    BackgroundColor="#EFF6FF"
                    StrokeShape="RoundRectangle 8"
                    Stroke="#BFDBFE" StrokeThickness="1"
                    Padding="14,8" Margin="0,0,0,8"
                    IsVisible="{Binding SelectedNode, Converter={StaticResource NullToBoolConverter}}">
                <HorizontalStackLayout Spacing="16">
                    <Label Text="{Binding SelectedNode.Name, StringFormat='• {0}'}"
                           FontSize="13" FontAttributes="Bold" TextColor="#1D4ED8" />
                    <Label Text="{Binding SelectedNode.X, StringFormat='x={0:F0}'}"
                           FontSize="12" TextColor="#64748B" VerticalOptions="Center" />
                    <Label Text="{Binding SelectedNode.Y, StringFormat='y={0:F0}'}"
                           FontSize="12" TextColor="#64748B" VerticalOptions="Center" />
                    <Border Padding="6,2" StrokeShape="RoundRectangle 4"
                            BackgroundColor="#EDE9FE" StrokeThickness="0"
                            IsVisible="{Binding SelectedNode.IsTransition}">
                        <Label Text="переход" FontSize="11" TextColor="#7C3AED" />
                    </Border>
                    <Border Padding="6,2" StrokeShape="RoundRectangle 4"
                            BackgroundColor="#DCFCE7" StrokeThickness="0"
                            IsVisible="{Binding SelectedNode.IsExit}">
                        <Label Text="выход" FontSize="11" TextColor="#15803D" />
                    </Border>
                </HorizontalStackLayout>
            </Border>

            <!-- Canvas -->
            <Border Grid.Row="4"
                    StrokeShape="RoundRectangle 14"
                    Stroke="#E2E8F0" StrokeThickness="1"
                    BackgroundColor="White" Padding="0">
                <controls:SvgView x:Name="AdminCanvas"
                                  FloorSvgPath="{Binding SelectedFloor.SvgPath}"
                                  Nodes="{Binding CurrentNodes}"
                                  Edges="{Binding CurrentEdges}"
                                  SelectedNode="{Binding SelectedNode}"
                                  BoundaryPreview="{Binding BoundaryPreview}"
                                  SelectedBoundaryVertexIndex="{Binding SelectedBoundaryVertexIndex, Mode=TwoWay}"
                                  SelectedBoundaryPolygonIndex="{Binding SelectedBoundaryPolygonIndex, Mode=TwoWay}"
                                  ShowGraph="True"
                                  IsAdminMode="True"
                                  IsDragMode="{Binding IsMoveMode}"
                                  HighlightedNodeId="{Binding SelectedNode.Id}"
                                  HorizontalOptions="Fill"
                                  VerticalOptions="Fill" />
            </Border>

            <!-- Рёбра выбранной точки -->
            <Border Grid.Row="2"
                    BackgroundColor="#EFF6FF"
                    StrokeShape="RoundRectangle 8"
                    Stroke="#BFDBFE" StrokeThickness="1"
                    Padding="14,8" Margin="0,0,0,8"
                    IsVisible="{Binding HasSelectedNodeEdges}">
                <HorizontalStackLayout Spacing="8" Padding="0">
                    <Label Text="Связи:"
                           FontSize="12" FontAttributes="Bold" TextColor="#1D4ED8"
                           VerticalOptions="Center"/>
                    <HorizontalStackLayout Spacing="6"
                                           BindableLayout.ItemsSource="{Binding SelectedNodeEdges}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:SelectedEdgeItem">
                                <Border BackgroundColor="#DBEAFE"
                                        StrokeShape="RoundRectangle 6"
                                        Stroke="#BFDBFE" StrokeThickness="1"
                                        Padding="10,4" Margin="0">
                                    <Label Text="{Binding OtherNodeName}"
                                           FontSize="12" TextColor="#1D4ED8"
                                           VerticalOptions="Center" HorizontalOptions="Center" />
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnEdgeButtonClicked" />
                                    </Border.GestureRecognizers>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </HorizontalStackLayout>
            </Border>

            <!-- ═══ PHONE BOTTOM TOOLBAR (hidden on desktop) ═══ -->
            <Border Grid.Row="5" BackgroundColor="#0F172A" Padding="8,6"
                    StrokeThickness="0"
                    IsVisible="{OnIdiom Phone=True, Default=False}">
                <ScrollView Orientation="Horizontal">
                    <HorizontalStackLayout Spacing="5" Padding="0,2">
                        <Button Text="+ Ауд."
                                Command="{Binding SetAddModeCommand}"
                                BackgroundColor="{Binding IsAddMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#2563EB|#1E293B'}"
                                TextColor="{Binding IsAddMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#94A3B8'}"
                                FontSize="12" WidthRequest="82" HeightRequest="46" CornerRadius="8" />
                        <Button Text="🪜 Лест."
                                Command="{Binding SetStaircaseModeCommand}"
                                BackgroundColor="{Binding IsStaircaseMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#7C3AED|#1E293B'}"
                                TextColor="{Binding IsStaircaseMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#94A3B8'}"
                                FontSize="12" WidthRequest="82" HeightRequest="46" CornerRadius="8" />
                        <Button Text="🛗 Лифт"
                                Command="{Binding SetElevatorModeCommand}"
                                BackgroundColor="{Binding IsElevatorMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#0369A1|#1E293B'}"
                                TextColor="{Binding IsElevatorMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#94A3B8'}"
                                FontSize="12" WidthRequest="82" HeightRequest="46" CornerRadius="8" />
                        <Button Text="🚩 Вых."
                                Command="{Binding SetExitModeCommand}"
                                BackgroundColor="{Binding IsExitMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#15803D|#1E293B'}"
                                TextColor="{Binding IsExitMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#94A3B8'}"
                                FontSize="12" WidthRequest="82" HeightRequest="46" CornerRadius="8" />
                        <Button Text="🚪 Эвак."
                                Command="{Binding SetEvacuationExitModeCommand}"
                                BackgroundColor="{Binding IsEvacuationExitMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#7F1D1D|#1E293B'}"
                                TextColor="{Binding IsEvacuationExitMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#94A3B8'}"
                                FontSize="12" WidthRequest="82" HeightRequest="46" CornerRadius="8" />
                        <Button Text="••• Проч."
                                Command="{Binding SetOtherModeCommand}"
                                BackgroundColor="{Binding IsOtherMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#B45309|#1E293B'}"
                                TextColor="{Binding IsOtherMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#94A3B8'}"
                                FontSize="12" WidthRequest="82" HeightRequest="46" CornerRadius="8" />
                        <Button Text="🛤 Кор."
                                Command="{Binding SetCorridorModeCommand}"
                                BackgroundColor="{Binding IsCorridorMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#0F766E|#1E293B'}"
                                TextColor="{Binding IsCorridorMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#94A3B8'}"
                                FontSize="12" WidthRequest="82" HeightRequest="46" CornerRadius="8" />
                        <Button Text="✓ Кор."
                                Command="{Binding FinishCorridorCommand}"
                                IsVisible="{Binding IsCorridorMode}"
                                BackgroundColor="#064E3B" TextColor="#6EE7B7"
                                FontSize="12" FontAttributes="Bold" WidthRequest="82" HeightRequest="46" CornerRadius="8" />
                        <Button Text="✏️ Движ"
                                Command="{Binding SetMoveModeCommand}"
                                BackgroundColor="{Binding IsMoveMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#7C3AED|#1E293B'}"
                                TextColor="{Binding IsMoveMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#94A3B8'}"
                                FontSize="12" WidthRequest="82" HeightRequest="46" CornerRadius="8" />
                        <Button Text="✓ Перем."
                                Command="{Binding ConfirmMoveCommand}"
                                IsVisible="{Binding IsMoveMode}"
                                BackgroundColor="#4C1D95" TextColor="#C4B5FD"
                                FontSize="12" FontAttributes="Bold" WidthRequest="82" HeightRequest="46" CornerRadius="8" />
                        <Button Text="↔ Join"
                                Command="{Binding SetConnectModeCommand}"
                                BackgroundColor="{Binding IsConnectMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#15803D|#1E293B'}"
                                TextColor="{Binding IsConnectMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#94A3B8'}"
                                FontSize="12" WidthRequest="82" HeightRequest="46" CornerRadius="8" />
                        <Button Text="✕ Разъед"
                                Command="{Binding SetDisconnectModeCommand}"
                                BackgroundColor="{Binding IsDisconnectMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#C2410C|#1E293B'}"
                                TextColor="{Binding IsDisconnectMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#94A3B8'}"
                                FontSize="12" WidthRequest="86" HeightRequest="46" CornerRadius="8" />
                        <Button Text="📐 Гран."
                                Command="{Binding SetBoundaryModeCommand}"
                                BackgroundColor="{Binding IsBoundaryMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#D97706|#1E293B'}"
                                TextColor="{Binding IsBoundaryMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#94A3B8'}"
                                FontSize="12" WidthRequest="82" HeightRequest="46" CornerRadius="8" />
                        <Button Text="✓ Гран."
                                Command="{Binding FinishBoundaryCommand}"
                                IsVisible="{Binding IsBoundaryMode}"
                                BackgroundColor="#92400E" TextColor="#FDE68A"
                                FontSize="12" FontAttributes="Bold" WidthRequest="82" HeightRequest="46" CornerRadius="8" />
                        <Button Text="🗑 Удал"
                                Command="{Binding DeleteSelectedCommand}"
                                BackgroundColor="#1E293B" TextColor="#F87171"
                                FontSize="12" WidthRequest="82" HeightRequest="46" CornerRadius="8" />
                        <Button Text="✕ Отм."
                                Command="{Binding CancelActionCommand}"
                                BackgroundColor="#1E3A5F" TextColor="#93C5FD"
                                FontSize="12" WidthRequest="78" HeightRequest="46" CornerRadius="8" />
                        <Button Text="💾 Сохр."
                                Command="{Binding SaveCommand}"
                                BackgroundColor="#2563EB" TextColor="White"
                                FontSize="12" FontAttributes="Bold" WidthRequest="82" HeightRequest="46" CornerRadius="8" />
                    </HorizontalStackLayout>
                </ScrollView>
            </Border>

        </Grid>
        </Grid>
        <!-- end map mode grid -->

        <!-- ═══════════════════════════════════════
             MANAGEMENT MODE  (Row 1)
             ═══════════════════════════════════════ -->
        <Grid Grid.Row="1" IsVisible="{Binding IsManagementMode}"
              RowDefinitions="Auto,*" BackgroundColor="#F1F5F9">

            <!-- ─── Sub-tab bar ─── -->
            <Grid Grid.Row="0" ColumnDefinitions="*,*,*" BackgroundColor="#0F172A" HeightRequest="44">
                <Button Grid.Column="0" Text="👥  Пользователи"
                        Command="{Binding SwitchToUsersTabCommand}"
                        BackgroundColor="{Binding IsUsersTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#1E3A5F|Transparent'}"
                        TextColor="{Binding IsUsersTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#475569'}"
                        FontSize="12" CornerRadius="0" BorderWidth="0" />
                <Button Grid.Column="1" Text="🏛  Факультеты"
                        Command="{Binding SwitchToDepartmentsTabCommand}"
                        BackgroundColor="{Binding IsDepartmentsTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#1E3A5F|Transparent'}"
                        TextColor="{Binding IsDepartmentsTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#475569'}"
                        FontSize="12" CornerRadius="0" BorderWidth="0" />
                <Button Grid.Column="2" Text="📅  Расписание"
                        Command="{Binding SwitchToScheduleTabCommand}"
                        BackgroundColor="{Binding IsScheduleTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#1E3A5F|Transparent'}"
                        TextColor="{Binding IsScheduleTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#475569'}"
                        FontSize="12" CornerRadius="0" BorderWidth="0" />
            </Grid>

            <!-- ─── USERS SUB-TAB ─── -->
            <ScrollView Grid.Row="1" IsVisible="{Binding IsUsersTab}" Padding="16">
                <VerticalStackLayout Spacing="10">

                    <!-- Students tree: Faculty → Group → Student -->
                    <Label Text="СТУДЕНТЫ" FontSize="11" CharacterSpacing="1.5"
                           TextColor="#64748B" Margin="0,0,0,4" />
                    <CollectionView ItemsSource="{Binding StudentFaculties}" SelectionMode="None">
                        <CollectionView.EmptyView>
                            <Label Text="Нет добавленных студентов" TextColor="#94A3B8"
                                   HorizontalOptions="Center" Margin="0,12" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="{x:Null}">
                                <!-- Faculty card -->
                                <Border Margin="0,4" Padding="0"
                                        BackgroundColor="White"
                                        StrokeShape="RoundRectangle 12"
                                        Stroke="#E2E8F0" StrokeThickness="1">
                                    <VerticalStackLayout>
                                        <!-- Faculty header: tap to toggle -->
                                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,12" ColumnSpacing="8">
                                            <Label Grid.Column="0" Text="{Binding ChevronText}"
                                                   FontSize="14" TextColor="#6B7280" VerticalOptions="Center" />
                                            <Label Grid.Column="1" Text="{Binding FacultyName}"
                                                   FontSize="15" FontAttributes="Bold" TextColor="#0F172A"
                                                   VerticalOptions="Center" />
                                            <Label Grid.Column="2" Text="{Binding StudentCount, StringFormat='{0} ст.'}"
                                                   FontSize="12" TextColor="#94A3B8" VerticalOptions="Center" />
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding ToggleCommand}" />
                                            </Grid.GestureRecognizers>
                                        </Grid>
                                        <!-- Groups (visible when faculty expanded) -->
                                        <CollectionView ItemsSource="{Binding Groups}" SelectionMode="None"
                                                        IsVisible="{Binding IsExpanded}" Margin="0,0,0,6">
                                            <CollectionView.ItemTemplate>
                                                <DataTemplate x:DataType="{x:Null}">
                                                    <VerticalStackLayout>
                                                        <!-- Group header -->
                                                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="20,6,14,4" ColumnSpacing="6">
                                                            <Label Grid.Column="0" Text="{Binding ChevronText}"
                                                                   FontSize="12" TextColor="#6B7280" VerticalOptions="Center" />
                                                            <Label Grid.Column="1" Text="{Binding GroupName}"
                                                                   FontSize="13" FontAttributes="Bold" TextColor="#059669"
                                                                   VerticalOptions="Center" />
                                                            <Label Grid.Column="2" Text="{Binding Students.Count, StringFormat='{0} ст.'}"
                                                                   FontSize="11" TextColor="#94A3B8" VerticalOptions="Center" />
                                                            <Grid.GestureRecognizers>
                                                                <TapGestureRecognizer Command="{Binding ToggleCommand}" />
                                                            </Grid.GestureRecognizers>
                                                        </Grid>
                                                        <!-- Students in group (visible when group expanded) -->
                                                        <CollectionView ItemsSource="{Binding Students}" SelectionMode="None"
                                                                        IsVisible="{Binding IsExpanded}" Margin="28,0,8,4">
                                                            <CollectionView.ItemTemplate>
                                                                <DataTemplate x:DataType="{x:Null}">
                                                                    <Border Padding="10,8" Margin="0,2"
                                                                            BackgroundColor="#F8FAFC"
                                                                            StrokeShape="RoundRectangle 8"
                                                                            Stroke="#E2E8F0" StrokeThickness="1">
                                                                        <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="5">
                                                                            <VerticalStackLayout Grid.Column="0" Spacing="1" VerticalOptions="Center">
                                                                                <Label Text="{Binding DisplayName}"
                                                                                       FontSize="13" TextColor="#1E293B"
                                                                                       FontAttributes="Bold" />
                                                                                <Label Text="{Binding Login}"
                                                                                       FontSize="11" TextColor="#94A3B8" />
                                                                            </VerticalStackLayout>
                                                                            <Button Grid.Column="1" Text="🔑"
                                                                                    Command="{Binding Source={x:Reference AdminRoot}, Path=BindingContext.ChangeStudentPasswordCommand}"
                                                                                    CommandParameter="{Binding .}"
                                                                                    BackgroundColor="#FFF7ED" TextColor="#D97706"
                                                                                    WidthRequest="34" HeightRequest="34"
                                                                                    CornerRadius="6" Padding="0" FontSize="12"
                                                                                    VerticalOptions="Center" />
                                                                            <Button Grid.Column="2" Text="✏"
                                                                                    Command="{Binding Source={x:Reference AdminRoot}, Path=BindingContext.EditStudentCommand}"
                                                                                    CommandParameter="{Binding .}"
                                                                                    BackgroundColor="#EFF6FF" TextColor="#2563EB"
                                                                                    WidthRequest="34" HeightRequest="34"
                                                                                    CornerRadius="6" Padding="0" FontSize="12"
                                                                                    VerticalOptions="Center" />
                                                                            <Button Grid.Column="3" Text="🗑"
                                                                                    Command="{Binding Source={x:Reference AdminRoot}, Path=BindingContext.RemoveStudentCommand}"
                                                                                    CommandParameter="{Binding .}"
                                                                                    BackgroundColor="#FEF2F2" TextColor="#DC2626"
                                                                                    WidthRequest="34" HeightRequest="34"
                                                                                    CornerRadius="6" Padding="0" FontSize="12"
                                                                                    VerticalOptions="Center" />
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </CollectionView.ItemTemplate>
                                                        </CollectionView>
                                                    </VerticalStackLayout>
                                                </DataTemplate>
                                            </CollectionView.ItemTemplate>
                                        </CollectionView>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Add student form -->
                    <BoxView HeightRequest="1" BackgroundColor="#E2E8F0" Margin="0,6" />
                    <Label Text="ДОБАВИТЬ СТУДЕНТА" FontSize="11" CharacterSpacing="1.5"
                           TextColor="#64748B" />
                    <Border Padding="16" StrokeShape="RoundRectangle 12"
                            BackgroundColor="White" Stroke="#E2E8F0" StrokeThickness="1">
                        <VerticalStackLayout Spacing="8">
                            <Entry Placeholder="Имя (отображаемое)"
                                   Text="{Binding NewStudentName, Mode=TwoWay}"
                                   TextColor="#1E293B" BackgroundColor="#F8FAFC" FontSize="14" />
                            <Entry Placeholder="Логин"
                                   Text="{Binding NewStudentLogin, Mode=TwoWay}"
                                   TextColor="#1E293B" BackgroundColor="#F8FAFC" FontSize="14" />
                            <Entry Placeholder="Пароль" IsPassword="True"
                                   Text="{Binding NewStudentPassword, Mode=TwoWay}"
                                   TextColor="#1E293B" BackgroundColor="#F8FAFC" FontSize="14" />

                            <!-- Department + Group tree picker -->
                            <Label Text="ФАКУЛЬТЕТ И ГРУППА" FontSize="10" CharacterSpacing="1.5" TextColor="#94A3B8" Margin="0,4,0,0" />
                            <Border Padding="12,10" BackgroundColor="#EFF6FF"
                                    StrokeShape="RoundRectangle 8" Stroke="#BFDBFE" StrokeThickness="1">
                                <Label FontSize="13">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="🎓 " />
                                            <Span Text="{Binding NewStudentDeptDisplay}" TextColor="#1E40AF" FontAttributes="Bold" />
                                            <Span Text=" › " TextColor="#94A3B8" />
                                            <Span Text="{Binding NewStudentGroupDisplay}" TextColor="#15803D" FontAttributes="Bold" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </Border>
                            <Border Padding="0" BackgroundColor="#F8FAFC"
                                    StrokeShape="RoundRectangle 10" Stroke="#E2E8F0" StrokeThickness="1">
                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding StudentDeptGroups}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="{x:Null}">
                                            <VerticalStackLayout>
                                                <!-- Dept header -->
                                                <Border Padding="12,10" BackgroundColor="#DBEAFE" StrokeThickness="0">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <Label Grid.Column="0" Text="{Binding Name}"
                                                               FontSize="13" FontAttributes="Bold" TextColor="#1E40AF"
                                                               VerticalOptions="Center" />
                                                        <Label Grid.Column="1" Text="{Binding ChevronText}"
                                                               FontSize="12" TextColor="#60A5FA" VerticalOptions="Center" />
                                                    </Grid>
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding ToggleCommand}" />
                                                    </Border.GestureRecognizers>
                                                </Border>
                                                <!-- Groups -->
                                                <VerticalStackLayout IsVisible="{Binding IsExpanded}"
                                                                     BindableLayout.ItemsSource="{Binding Groups}">
                                                    <BindableLayout.ItemTemplate>
                                                        <DataTemplate x:DataType="{x:Null}">
                                                            <Border Padding="22,10"
                                                                    BackgroundColor="{Binding IsSelected, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#DBEAFE|Transparent'}"
                                                                    StrokeShape="RoundRectangle 6" StrokeThickness="0">
                                                                <Label Text="{Binding Name}" FontSize="13"
                                                                       TextColor="{Binding IsSelected, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#1E40AF|#1E293B'}" />
                                                                <Border.GestureRecognizers>
                                                                    <TapGestureRecognizer
                                                                        Command="{Binding Source={x:Reference AdminRoot}, Path=BindingContext.SelectStudentGroupCommand}"
                                                                        CommandParameter="{Binding .}" />
                                                                </Border.GestureRecognizers>
                                                            </Border>
                                                        </DataTemplate>
                                                    </BindableLayout.ItemTemplate>
                                                </VerticalStackLayout>
                                                <BoxView HeightRequest="1" BackgroundColor="#E2E8F0" />
                                            </VerticalStackLayout>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </Border>

                            <Button Text="✚  Добавить студента"
                                    Command="{Binding AddStudentCommand}"
                                    BackgroundColor="#2563EB" TextColor="White"
                                    FontSize="14" HeightRequest="46" CornerRadius="10"
                                    FontAttributes="Bold" Margin="0,4,0,0" />
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>

            <!-- ─── DEPARTMENTS SUB-TAB ─── -->
            <Grid Grid.Row="1" IsVisible="{Binding IsDepartmentsTab}" RowDefinitions="*,Auto" Padding="16">

                <!-- Departments list -->
                <ScrollView Grid.Row="0">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="ФАКУЛЬТЕТЫ" FontSize="11" CharacterSpacing="1.5"
                               TextColor="#64748B" Margin="0,0,0,4" />
                        <CollectionView ItemsSource="{Binding DeptViewItems}"
                                        SelectionMode="None">
                            <CollectionView.EmptyView>
                                <Label Text="Нет факультетов. Добавьте первый." TextColor="#94A3B8"
                                       HorizontalOptions="Center" Margin="0,20" />
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="{x:Null}">
                                    <Border Padding="0" Margin="0,4"
                                            BackgroundColor="White" StrokeShape="RoundRectangle 12"
                                            Stroke="{Binding IsSelected, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#2563EB|#E2E8F0'}"
                                            StrokeThickness="2">
                                        <VerticalStackLayout>
                                            <!-- Faculty header: tap to expand/collapse + select -->
                                            <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                                                  Padding="14,12" ColumnSpacing="6"
                                                  BackgroundColor="{Binding IsSelected, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#EFF6FF|Transparent'}">
                                                <Label Grid.Column="0" Text="{Binding ChevronText}"
                                                       FontSize="14" TextColor="#6B7280" VerticalOptions="Center" />
                                                <Label Grid.Column="1" Text="{Binding Name}"
                                                       FontSize="15" FontAttributes="Bold"
                                                       TextColor="{Binding IsSelected, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#1E40AF|#0F172A'}"
                                                       VerticalOptions="Center" />
                                                <Button Grid.Column="2" Text="✏"
                                                        Command="{Binding Source={x:Reference AdminRoot}, Path=BindingContext.RenameDepartmentCommand}"
                                                        CommandParameter="{Binding Dept}"
                                                        BackgroundColor="#EFF6FF" TextColor="#2563EB"
                                                        WidthRequest="34" HeightRequest="34"
                                                        CornerRadius="8" Padding="0" FontSize="13" />
                                                <Button Grid.Column="3" Text="🗑"
                                                        Command="{Binding Source={x:Reference AdminRoot}, Path=BindingContext.RemoveDepartmentCommand}"
                                                        CommandParameter="{Binding Dept}"
                                                        BackgroundColor="#FEF2F2" TextColor="#DC2626"
                                                        WidthRequest="34" HeightRequest="34"
                                                        CornerRadius="8" Padding="0" FontSize="13" />
                                                <Grid.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding ToggleCommand}" />
                                                </Grid.GestureRecognizers>
                                            </Grid>
                                            <!-- Groups (shown when expanded) -->
                                            <CollectionView ItemsSource="{Binding Groups}" Margin="12,0,8,10"
                                                            IsVisible="{Binding IsExpanded}" SelectionMode="None">
                                                <CollectionView.EmptyView>
                                                    <Label Text="Нет групп" FontSize="12"
                                                           TextColor="#CBD5E1" Margin="4,4" />
                                                </CollectionView.EmptyView>
                                                <CollectionView.ItemTemplate>
                                                    <DataTemplate x:DataType="{x:Null}">
                                                        <Border Padding="4,3" Margin="0,2"
                                                                BackgroundColor="{Binding IsSelected, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#EFF6FF|Transparent'}"
                                                                StrokeShape="RoundRectangle 8"
                                                                Stroke="{Binding IsSelected, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#2563EB|Transparent'}"
                                                                StrokeThickness="1">
                                                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="4">
                                                                <Label Grid.Column="0" Text="{Binding Name}"
                                                                       FontSize="13"
                                                                       TextColor="{Binding IsSelected, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#1E40AF|#334155'}"
                                                                       VerticalOptions="Center" />
                                                                <Button Grid.Column="1" Text="✏"
                                                                        Command="{Binding Source={x:Reference AdminRoot}, Path=BindingContext.RenameGroupCommand}"
                                                                        CommandParameter="{Binding .}"
                                                                        BackgroundColor="#EFF6FF" TextColor="#2563EB"
                                                                        WidthRequest="30" HeightRequest="30"
                                                                        CornerRadius="6" Padding="0" FontSize="12" />
                                                                <Button Grid.Column="2" Text="✕"
                                                                        Command="{Binding Source={x:Reference AdminRoot}, Path=BindingContext.RemoveGroupCommand}"
                                                                        CommandParameter="{Binding .}"
                                                                        BackgroundColor="#FEF2F2" TextColor="#DC2626"
                                                                        WidthRequest="30" HeightRequest="30"
                                                                        CornerRadius="6" Padding="0" FontSize="12" />
                                                            </Grid>
                                                            <Border.GestureRecognizers>
                                                                <TapGestureRecognizer Command="{Binding Source={x:Reference AdminRoot}, Path=BindingContext.SelectGroupCommand}" CommandParameter="{Binding .}" />
                                                            </Border.GestureRecognizers>
                                                        </Border>
                                                    </DataTemplate>
                                                </CollectionView.ItemTemplate>
                                            </CollectionView>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </ScrollView>

                <!-- Bottom action bar -->
                <Border Grid.Row="1" Padding="12" Margin="0,8,0,0"
                        BackgroundColor="White" StrokeShape="RoundRectangle 12"
                        Stroke="#E2E8F0" StrokeThickness="1">
                    <VerticalStackLayout Spacing="8">
                        <!-- Add group (only when dept selected) -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8"
                              IsVisible="{Binding HasSelectedDept}">
                            <Entry Grid.Column="0" Placeholder="Название группы (напр. ИС-21)"
                                   Text="{Binding NewGroupName, Mode=TwoWay}"
                                   TextColor="#1E293B" BackgroundColor="#F8FAFC" FontSize="13" />
                            <Button Grid.Column="1" Text="+ Группа"
                                    Command="{Binding AddGroupCommand}"
                                    BackgroundColor="#2563EB" TextColor="White"
                                    FontSize="13" HeightRequest="44" CornerRadius="8" Padding="10,0" />
                        </Grid>
                        <Label Text="Выберите факультет выше, чтобы добавить группу"
                               FontSize="12" TextColor="#94A3B8" HorizontalOptions="Center" />
                        <BoxView HeightRequest="1" BackgroundColor="#E2E8F0" />
                        <!-- Add department -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Entry Grid.Column="0" Placeholder="Название факультета"
                                   Text="{Binding NewDeptName, Mode=TwoWay}"
                                   TextColor="#1E293B" BackgroundColor="#F8FAFC" FontSize="13" />
                            <Button Grid.Column="1" Text="+ Факультет"
                                    Command="{Binding AddDepartmentCommand}"
                                    BackgroundColor="#059669" TextColor="White"
                                    FontSize="13" HeightRequest="44" CornerRadius="8" Padding="10,0" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

            </Grid>
            <!-- end departments sub-tab -->

            <!-- ─── SCHEDULE SUB-TAB ─── -->
            <ScrollView Grid.Row="1" IsVisible="{Binding IsScheduleTab}" Padding="16">
                <VerticalStackLayout Spacing="12">

                    <!-- ═══ Entries List ═══ -->
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                        <Label Grid.Column="0" Text="РАСПИСАНИЕ ЗАНЯТИЙ" FontSize="11" CharacterSpacing="1.5"
                               TextColor="#64748B" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="🗑 Удалить все"
                                Command="{Binding ClearAllScheduleEntriesCommand}"
                                BackgroundColor="#FEF2F2" TextColor="#DC2626"
                                FontSize="11" HeightRequest="30" CornerRadius="8" Padding="8,0" />
                    </Grid>

                    <!-- View mode toggle -->
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="4">
                        <Button Grid.Column="0" Text="📋 Все"
                                Command="{Binding SwitchScheduleViewCommand}" CommandParameter="0"
                                BackgroundColor="{Binding IsScheduleViewAll, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#2563EB|#1E293B'}"
                                TextColor="{Binding IsScheduleViewAll, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#64748B'}"
                                FontSize="12" HeightRequest="36" CornerRadius="8" />
                        <Button Grid.Column="1" Text="🏫 Здание"
                                Command="{Binding SwitchScheduleViewCommand}" CommandParameter="1"
                                BackgroundColor="{Binding IsScheduleViewRoom, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#2563EB|#1E293B'}"
                                TextColor="{Binding IsScheduleViewRoom, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#64748B'}"
                                FontSize="12" HeightRequest="36" CornerRadius="8" />
                        <Button Grid.Column="2" Text="👥 Группа"
                                Command="{Binding SwitchScheduleViewCommand}" CommandParameter="2"
                                BackgroundColor="{Binding IsScheduleViewGroup, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#2563EB|#1E293B'}"
                                TextColor="{Binding IsScheduleViewGroup, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#64748B'}"
                                FontSize="12" HeightRequest="36" CornerRadius="8" />
                    </Grid>

                    <!-- Group search filter -->
                    <Border Padding="10,0" StrokeShape="RoundRectangle 10"
                            Stroke="#E2E8F0" StrokeThickness="1" BackgroundColor="White">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6">
                            <Label Grid.Column="0" Text="🔍" FontSize="14"
                                   VerticalOptions="Center" TextColor="#94A3B8" />
                            <Entry Grid.Column="1"
                                   Text="{Binding ScheduleGroupFilter, Mode=TwoWay}"
                                   Placeholder="Поиск по группе..."
                                   PlaceholderColor="#94A3B8"
                                   FontSize="13" TextColor="#0F172A"
                                   BackgroundColor="Transparent"
                                   HeightRequest="40" />
                            <Button Grid.Column="2" Text="✕"
                                    Command="{Binding ClearScheduleFilterCommand}"
                                    IsVisible="{Binding ScheduleGroupFilter, Converter={StaticResource StringNotEmptyConverter}}"
                                    BackgroundColor="Transparent" TextColor="#94A3B8"
                                    FontSize="12" WidthRequest="32" HeightRequest="32" Padding="0" />
                        </Grid>
                    </Border>

                    <!-- ── Flat list (mode 0) ── -->
                    <CollectionView ItemsSource="{Binding ScheduleEntriesFiltered}" SelectionMode="None"
                                    IsVisible="{Binding IsScheduleViewAll}">
                        <CollectionView.EmptyView>
                            <Label Text="Расписание пустое. Добавьте занятие ниже."
                                   TextColor="#94A3B8" HorizontalOptions="Center" Margin="0,12" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="{x:Null}">
                                <Border Padding="14,12" Margin="0,3"
                                        BackgroundColor="White" StrokeShape="RoundRectangle 12"
                                        Stroke="#E2E8F0" StrokeThickness="1">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                                            <Label FontSize="14" FontAttributes="Bold" TextColor="#0F172A">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="🏫 " />
                                                        <Span Text="{Binding RoomName}" TextColor="#2563EB" FontAttributes="Bold"/>
                                                        <Span Text="  →  " TextColor="#94A3B8"/>
                                                        <Span Text="{Binding GroupName}" TextColor="#059669" FontAttributes="Bold"/>
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                            <Label FontSize="12" TextColor="#334155">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="📅 " />
                                                        <Span Text="{Binding DisplayDate}" FontAttributes="Bold"/>
                                                        <Span Text="  " />
                                                        <Span Text="{Binding TimeSlots[0]}" />
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                            <Label FontSize="12" TextColor="#64748B">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="👤 " />
                                                        <Span Text="{Binding PersonCount}" FontAttributes="Bold"/>
                                                        <Span Text=" студентов" />
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                        </VerticalStackLayout>
                                        <Button Grid.Column="1" Text="🗑"
                                                Command="{Binding Source={x:Reference AdminRoot}, Path=BindingContext.RemoveScheduleEntryCommand}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="#FEF2F2" TextColor="#DC2626"
                                                WidthRequest="40" HeightRequest="40"
                                                CornerRadius="8" Padding="0" FontSize="14"
                                                VerticalOptions="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- ── By Building/Floor (mode 1) ── -->
                    <VerticalStackLayout IsVisible="{Binding IsScheduleViewRoom}" Spacing="4">
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding ScheduleEntriesViewByRoom}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="{x:Null}">
                                    <Border Margin="0,4" Padding="0" BackgroundColor="White"
                                            StrokeShape="RoundRectangle 10" Stroke="#BFDBFE" StrokeThickness="1">
                                        <VerticalStackLayout>
                                            <!-- Building header -->
                                            <Border Padding="12,10" BackgroundColor="#DBEAFE" StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 10">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <Label Grid.Column="0" Text="{Binding BuildingName}"
                                                           FontSize="14" FontAttributes="Bold" TextColor="#1E40AF" VerticalOptions="Center" />
                                                    <Label Grid.Column="1" Text="{Binding ChevronText}"
                                                           FontSize="13" TextColor="#3B82F6" VerticalOptions="Center" />
                                                    <Grid.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding ToggleCommand}" />
                                                    </Grid.GestureRecognizers>
                                                </Grid>
                                            </Border>
                                            <!-- Floors -->
                                            <VerticalStackLayout IsVisible="{Binding IsExpanded}"
                                                                 BindableLayout.ItemsSource="{Binding Floors}">
                                                <BindableLayout.ItemTemplate>
                                                    <DataTemplate x:DataType="{x:Null}">
                                                        <VerticalStackLayout>
                                                            <!-- Floor header -->
                                                            <Border Padding="16,8" BackgroundColor="#EFF6FF" StrokeThickness="0">
                                                                <Grid ColumnDefinitions="*,Auto">
                                                                    <Label Grid.Column="0" Text="{Binding FloorLabel}"
                                                                           FontSize="13" FontAttributes="Bold" TextColor="#3B82F6" VerticalOptions="Center" />
                                                                    <Label Grid.Column="1" Text="{Binding ChevronText}"
                                                                           FontSize="12" TextColor="#93C5FD" VerticalOptions="Center" />
                                                                    <Grid.GestureRecognizers>
                                                                        <TapGestureRecognizer Command="{Binding ToggleCommand}" />
                                                                    </Grid.GestureRecognizers>
                                                                </Grid>
                                                            </Border>
                                                            <!-- Days -->
                                                            <VerticalStackLayout IsVisible="{Binding IsExpanded}"
                                                                                 BindableLayout.ItemsSource="{Binding Days}" Padding="0,0">
                                                                <BindableLayout.ItemTemplate>
                                                                    <DataTemplate x:DataType="{x:Null}">
                                                                        <VerticalStackLayout>
                                                                            <!-- Day header -->
                                                                            <Border Padding="24,6" BackgroundColor="#F0F9FF" StrokeThickness="0">
                                                                                <Grid ColumnDefinitions="*,Auto">
                                                                                    <Label Grid.Column="0" Text="{Binding DayLabel}"
                                                                                           FontSize="12" FontAttributes="Bold" TextColor="#0284C7" VerticalOptions="Center" />
                                                                                    <Label Grid.Column="1" Text="{Binding ChevronText}"
                                                                                           FontSize="11" TextColor="#7DD3FC" VerticalOptions="Center" />
                                                                                    <Grid.GestureRecognizers>
                                                                                        <TapGestureRecognizer Command="{Binding ToggleCommand}" />
                                                                                    </Grid.GestureRecognizers>
                                                                                </Grid>
                                                                            </Border>
                                                                            <!-- Entries per day -->
                                                                            <VerticalStackLayout IsVisible="{Binding IsExpanded}"
                                                                                                 BindableLayout.ItemsSource="{Binding Entries}" Padding="8,0">
                                                                                <BindableLayout.ItemTemplate>
                                                                                    <DataTemplate x:DataType="{x:Null}">
                                                                                        <Border Padding="14,10" Margin="0,3"
                                                                                                BackgroundColor="White" StrokeShape="RoundRectangle 8"
                                                                                                Stroke="#E2E8F0" StrokeThickness="1">
                                                                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                                                                <VerticalStackLayout Grid.Column="0" Spacing="3">
                                                                                                    <Label Text="{Binding GroupName}" FontSize="13" FontAttributes="Bold" TextColor="#059669" />
                                                                                                    <Label FontSize="12" TextColor="#334155">
                                                                                                        <Label.FormattedText>
                                                                                                            <FormattedString>
                                                                                                                <Span Text="📅 " /><Span Text="{Binding DisplayDate}" FontAttributes="Bold"/>
                                                                                                                <Span Text="  " /><Span Text="{Binding TimeSlots[0]}" />
                                                                                                            </FormattedString>
                                                                                                        </Label.FormattedText>
                                                                                                    </Label>
                                                                                                    <Label FontSize="12" TextColor="#64748B">
                                                                                                        <Label.FormattedText>
                                                                                                            <FormattedString>
                                                                                                                <Span Text="👤 " /><Span Text="{Binding PersonCount}" FontAttributes="Bold"/><Span Text=" студентов" />
                                                                                                            </FormattedString>
                                                                                                        </Label.FormattedText>
                                                                                                    </Label>
                                                                                                    <Label Text="{Binding RoomName}" FontSize="12" TextColor="#94A3B8" />
                                                                                                </VerticalStackLayout>
                                                                                                <Button Grid.Column="1" Text="🗑"
                                                                                                        Command="{Binding Source={x:Reference AdminRoot}, Path=BindingContext.RemoveScheduleEntryCommand}"
                                                                                                        CommandParameter="{Binding .}"
                                                                                                        BackgroundColor="#FEF2F2" TextColor="#DC2626"
                                                                                                        WidthRequest="36" HeightRequest="36"
                                                                                                        CornerRadius="8" Padding="0" FontSize="13"
                                                                                                        VerticalOptions="Center" />
                                                                                            </Grid>
                                                                                        </Border>
                                                                                    </DataTemplate>
                                                                                </BindableLayout.ItemTemplate>
                                                                            </VerticalStackLayout>
                                                                        </VerticalStackLayout>
                                                                    </DataTemplate>
                                                                </BindableLayout.ItemTemplate>
                                                            </VerticalStackLayout>
                                                        </VerticalStackLayout>
                                                    </DataTemplate>
                                                </BindableLayout.ItemTemplate>
                                            </VerticalStackLayout>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <!-- ── By Faculty/Group (mode 2) ── -->
                    <VerticalStackLayout IsVisible="{Binding IsScheduleViewGroup}" Spacing="4">
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding ScheduleEntriesViewByGroup}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="{x:Null}">
                                    <Border Margin="0,4" Padding="0" BackgroundColor="White"
                                            StrokeShape="RoundRectangle 10" Stroke="#BBF7D0" StrokeThickness="1">
                                        <VerticalStackLayout>
                                            <!-- Faculty header -->
                                            <Border Padding="12,10" BackgroundColor="#DCFCE7" StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 10">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <Label Grid.Column="0" Text="{Binding FacultyName}"
                                                           FontSize="14" FontAttributes="Bold" TextColor="#15803D" VerticalOptions="Center" />
                                                    <Label Grid.Column="1" Text="{Binding ChevronText}"
                                                           FontSize="13" TextColor="#22C55E" VerticalOptions="Center" />
                                                    <Grid.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding ToggleCommand}" />
                                                    </Grid.GestureRecognizers>
                                                </Grid>
                                            </Border>
                                            <!-- Groups -->
                                            <VerticalStackLayout IsVisible="{Binding IsExpanded}"
                                                                 BindableLayout.ItemsSource="{Binding Groups}">
                                                <BindableLayout.ItemTemplate>
                                                    <DataTemplate x:DataType="{x:Null}">
                                                        <VerticalStackLayout>
                                                            <!-- Group header -->
                                                            <Border Padding="16,8" BackgroundColor="#F0FDF4" StrokeThickness="0">
                                                                <Grid ColumnDefinitions="*,Auto">
                                                                    <Label Grid.Column="0" Text="{Binding GroupName}"
                                                                           FontSize="13" FontAttributes="Bold" TextColor="#16A34A" VerticalOptions="Center" />
                                                                    <Label Grid.Column="1" Text="{Binding ChevronText}"
                                                                           FontSize="12" TextColor="#86EFAC" VerticalOptions="Center" />
                                                                    <Grid.GestureRecognizers>
                                                                        <TapGestureRecognizer Command="{Binding ToggleCommand}" />
                                                                    </Grid.GestureRecognizers>
                                                                </Grid>
                                                            </Border>
                                                            <!-- Entries -->
                                                            <VerticalStackLayout IsVisible="{Binding IsExpanded}"
                                                                                 BindableLayout.ItemsSource="{Binding Entries}" Padding="8,0">
                                                                <BindableLayout.ItemTemplate>
                                                                    <DataTemplate x:DataType="{x:Null}">
                                                                        <Border Padding="14,10" Margin="0,3"
                                                                                BackgroundColor="White" StrokeShape="RoundRectangle 8"
                                                                                Stroke="#E2E8F0" StrokeThickness="1">
                                                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                                                <VerticalStackLayout Grid.Column="0" Spacing="3">
                                                                                    <Label Text="{Binding RoomName}" FontSize="13" FontAttributes="Bold" TextColor="#2563EB" />
                                                                                    <Label FontSize="12" TextColor="#334155">
                                                                                        <Label.FormattedText>
                                                                                            <FormattedString>
                                                                                                <Span Text="📅 " /><Span Text="{Binding DisplayDate}" FontAttributes="Bold"/>
                                                                                                <Span Text="  " /><Span Text="{Binding TimeSlots[0]}" />
                                                                                            </FormattedString>
                                                                                        </Label.FormattedText>
                                                                                    </Label>
                                                                                    <Label FontSize="12" TextColor="#64748B">
                                                                                        <Label.FormattedText>
                                                                                            <FormattedString>
                                                                                                <Span Text="👤 " /><Span Text="{Binding PersonCount}" FontAttributes="Bold"/><Span Text=" студентов" />
                                                                                            </FormattedString>
                                                                                        </Label.FormattedText>
                                                                                    </Label>
                                                                                </VerticalStackLayout>
                                                                                <Button Grid.Column="1" Text="🗑"
                                                                                        Command="{Binding Source={x:Reference AdminRoot}, Path=BindingContext.RemoveScheduleEntryCommand}"
                                                                                        CommandParameter="{Binding .}"
                                                                                        BackgroundColor="#FEF2F2" TextColor="#DC2626"
                                                                                        WidthRequest="36" HeightRequest="36"
                                                                                        CornerRadius="8" Padding="0" FontSize="13"
                                                                                        VerticalOptions="Center" />
                                                                            </Grid>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </BindableLayout.ItemTemplate>
                                                            </VerticalStackLayout>
                                                        </VerticalStackLayout>
                                                    </DataTemplate>
                                                </BindableLayout.ItemTemplate>
                                            </VerticalStackLayout>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <!-- ═══ Add entry form ═══ -->
                    <BoxView HeightRequest="1" BackgroundColor="#E2E8F0" Margin="0,4" />
                    <Label Text="ДОБАВИТЬ ЗАНЯТИЕ" FontSize="11" CharacterSpacing="1.5"
                           TextColor="#64748B" Margin="0,0,0,2" />

                    <Border Padding="14" BackgroundColor="White"
                            StrokeShape="RoundRectangle 12" Stroke="#E2E8F0" StrokeThickness="1">
                        <VerticalStackLayout Spacing="12">

                            <!-- Day of week + Time -->
                            <Label Text="ДЕНЬ НЕДЕЛИ И ВРЕМЯ" FontSize="10" CharacterSpacing="1.5" TextColor="#94A3B8" />
                            <Picker ItemsSource="{Binding DayNames}"
                                    SelectedIndex="{Binding NewEntryDayOfWeek, Mode=TwoWay}"
                                    Title="Выберите день недели"
                                    TextColor="#1E293B" BackgroundColor="#F8FAFC" FontSize="13" />
                            <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="8">
                                <Entry Grid.Column="0" Placeholder="Начало 08:00"
                                       Text="{Binding NewEntryStart, Mode=TwoWay}"
                                       TextColor="#1E293B" BackgroundColor="#F8FAFC" FontSize="13" />
                                <Label Grid.Column="1" Text="–" FontSize="16"
                                       TextColor="#64748B" VerticalOptions="Center" />
                                <Entry Grid.Column="2" Placeholder="Конец 09:30"
                                       Text="{Binding NewEntryEnd, Mode=TwoWay}"
                                       TextColor="#1E293B" BackgroundColor="#F8FAFC" FontSize="13" />
                            </Grid>

                            <!-- Selected room summary -->
                            <BoxView HeightRequest="1" BackgroundColor="#F1F5F9" />
                            <Label Text="АУДИТОРИЯ" FontSize="10" CharacterSpacing="1.5" TextColor="#94A3B8" />
                            <Border Padding="12,10" BackgroundColor="#EFF6FF"
                                    StrokeShape="RoundRectangle 8" Stroke="#BFDBFE" StrokeThickness="1">
                                <Label FontSize="13">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="🏫 " />
                                            <Span Text="{Binding NewEntryRoomDisplay}"
                                                  TextColor="#1E40AF" FontAttributes="Bold" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </Border>

                            <!-- Room tree: Building → Floor → Room -->
                            <Border Padding="0" BackgroundColor="#F8FAFC"
                                    StrokeShape="RoundRectangle 10" Stroke="#E2E8F0" StrokeThickness="1">
                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding ScheduleRoomTree}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="{x:Null}">
                                            <VerticalStackLayout>
                                                <!-- Building header -->
                                                <Border Padding="12,10" BackgroundColor="#DBEAFE" StrokeThickness="0">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <Label Grid.Column="0" Text="{Binding BuildingName}"
                                                               FontSize="13" FontAttributes="Bold" TextColor="#1E40AF"
                                                               VerticalOptions="Center" />
                                                        <Label Grid.Column="1" Text="{Binding ChevronText}"
                                                               FontSize="12" TextColor="#3B82F6" VerticalOptions="Center" />
                                                    </Grid>
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding ToggleCommand}" />
                                                    </Border.GestureRecognizers>
                                                </Border>
                                                <!-- Floors (visible when expanded) -->
                                                <VerticalStackLayout IsVisible="{Binding IsExpanded}"
                                                                     BindableLayout.ItemsSource="{Binding Floors}">
                                                    <BindableLayout.ItemTemplate>
                                                        <DataTemplate x:DataType="{x:Null}">
                                                            <VerticalStackLayout>
                                                                <!-- Floor header -->
                                                                <Border Padding="20,8" BackgroundColor="#EFF6FF" StrokeThickness="0">
                                                                    <Grid ColumnDefinitions="*,Auto">
                                                                        <Label Grid.Column="0" Text="{Binding FloorLabel}"
                                                                               FontSize="12" FontAttributes="Bold" TextColor="#3B82F6"
                                                                               VerticalOptions="Center" />
                                                                        <Label Grid.Column="1" Text="{Binding ChevronText}"
                                                                               FontSize="11" TextColor="#93C5FD" VerticalOptions="Center" />
                                                                    </Grid>
                                                                    <Border.GestureRecognizers>
                                                                        <TapGestureRecognizer Command="{Binding ToggleCommand}" />
                                                                    </Border.GestureRecognizers>
                                                                </Border>
                                                                <!-- Rooms -->
                                                                <VerticalStackLayout IsVisible="{Binding IsExpanded}"
                                                                                     BindableLayout.ItemsSource="{Binding Rooms}">
                                                                    <BindableLayout.ItemTemplate>
                                                                        <DataTemplate x:DataType="{x:Null}">
                                                                            <Border Padding="30,10"
                                                                                    BackgroundColor="{Binding IsSelected, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#BFDBFE|Transparent'}"
                                                                                    StrokeShape="RoundRectangle 6" StrokeThickness="0">
                                                                                <Label Text="{Binding Name}"
                                                                                       FontSize="13"
                                                                                       TextColor="{Binding IsSelected, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#1E40AF|#1E293B'}" />
                                                                                <Border.GestureRecognizers>
                                                                                    <TapGestureRecognizer
                                                                                        Command="{Binding Source={x:Reference AdminRoot}, Path=BindingContext.SelectScheduleRoomCommand}"
                                                                                        CommandParameter="{Binding .}" />
                                                                                </Border.GestureRecognizers>
                                                                            </Border>
                                                                        </DataTemplate>
                                                                    </BindableLayout.ItemTemplate>
                                                                </VerticalStackLayout>
                                                            </VerticalStackLayout>
                                                        </DataTemplate>
                                                    </BindableLayout.ItemTemplate>
                                                </VerticalStackLayout>
                                                <BoxView HeightRequest="1" BackgroundColor="#E2E8F0" />
                                            </VerticalStackLayout>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </Border>

                            <!-- Selected group summary -->
                            <BoxView HeightRequest="1" BackgroundColor="#F1F5F9" />
                            <Label Text="ГРУППА" FontSize="10" CharacterSpacing="1.5" TextColor="#94A3B8" />
                            <Border Padding="12,10" BackgroundColor="#F0FDF4"
                                    StrokeShape="RoundRectangle 8" Stroke="#BBF7D0" StrokeThickness="1">
                                <Label FontSize="13">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="👥 " />
                                            <Span Text="{Binding NewEntryGroupDisplay}"
                                                  TextColor="#15803D" FontAttributes="Bold" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </Border>

                            <!-- Dept/Group tree: Department → Groups -->
                            <Border Padding="0" BackgroundColor="#F8FAFC"
                                    StrokeShape="RoundRectangle 10" Stroke="#E2E8F0" StrokeThickness="1">
                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding ScheduleDeptGroups}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="{x:Null}">
                                            <VerticalStackLayout>
                                                <!-- Dept header -->
                                                <Border Padding="12,10" BackgroundColor="#DCFCE7" StrokeThickness="0">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <Label Grid.Column="0" Text="{Binding Name}"
                                                               FontSize="13" FontAttributes="Bold" TextColor="#15803D"
                                                               VerticalOptions="Center" />
                                                        <Label Grid.Column="1" Text="{Binding ChevronText}"
                                                               FontSize="12" TextColor="#22C55E" VerticalOptions="Center" />
                                                    </Grid>
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding ToggleCommand}" />
                                                    </Border.GestureRecognizers>
                                                </Border>
                                                <!-- Groups -->
                                                <VerticalStackLayout IsVisible="{Binding IsExpanded}"
                                                                     BindableLayout.ItemsSource="{Binding Groups}">
                                                    <BindableLayout.ItemTemplate>
                                                        <DataTemplate x:DataType="{x:Null}">
                                                            <Border Padding="22,10"
                                                                    BackgroundColor="{Binding IsSelected, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#BBF7D0|Transparent'}"
                                                                    StrokeShape="RoundRectangle 6" StrokeThickness="0">
                                                                <VerticalStackLayout Spacing="1">
                                                                    <Label Text="{Binding Name}"
                                                                           FontSize="13"
                                                                           TextColor="{Binding IsSelected, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#15803D|#1E293B'}" />
                                                                    <Label FontSize="11" TextColor="#94A3B8">
                                                                        <Label.FormattedText>
                                                                            <FormattedString>
                                                                                <Span Text="👤 " /><Span Text="{Binding StudentCount}" FontAttributes="Bold"/><Span Text=" студентов" />
                                                                            </FormattedString>
                                                                        </Label.FormattedText>
                                                                    </Label>
                                                                </VerticalStackLayout>
                                                                <Border.GestureRecognizers>
                                                                    <TapGestureRecognizer
                                                                        Command="{Binding Source={x:Reference AdminRoot}, Path=BindingContext.SelectScheduleGroupCommand}"
                                                                        CommandParameter="{Binding .}" />
                                                                </Border.GestureRecognizers>
                                                            </Border>
                                                        </DataTemplate>
                                                    </BindableLayout.ItemTemplate>
                                                </VerticalStackLayout>
                                                <BoxView HeightRequest="1" BackgroundColor="#E2E8F0" />
                                            </VerticalStackLayout>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </Border>

                            <!-- Auto person count -->
                            <Border Padding="12,10" BackgroundColor="#FFF7ED"
                                    StrokeShape="RoundRectangle 8" Stroke="#FED7AA" StrokeThickness="1">
                                <Label FontSize="13">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="👤 Студентов в группе: " TextColor="#9A3412" />
                                            <Span Text="{Binding NewEntryPersonCountAuto}"
                                                  FontAttributes="Bold" TextColor="#EA580C" FontSize="15" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </Border>

                            <Button Text="📅  Добавить занятие"
                                    Command="{Binding AddScheduleEntryCommand}"
                                    BackgroundColor="#7C3AED" TextColor="White"
                                    FontSize="14" HeightRequest="48" CornerRadius="10"
                                    FontAttributes="Bold" Margin="0,4,0,0" />
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>
            <!-- end schedule sub-tab -->

        </Grid>
        <!-- end management mode -->

        <!-- ═══════════════════════════════════════
             QR CODE POPUP OVERLAY
             ═══════════════════════════════════════ -->
        <Grid Grid.Row="0" Grid.RowSpan="2"
              IsVisible="{Binding QrPopupVisible}"
              BackgroundColor="#80000000">
            <Border Padding="24"
                    WidthRequest="300"
                    HorizontalOptions="Center" VerticalOptions="Center"
                    BackgroundColor="#1E293B"
                    StrokeShape="RoundRectangle 16"
                    Stroke="#334155">
                <VerticalStackLayout Spacing="14">
                    <Label Text="{Binding QrPopupNodeName}"
                           FontSize="16" FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center" />
                    <!-- Actual deep-link URL — selectable for manual copy -->
                    <Border Padding="10,8"
                            StrokeShape="RoundRectangle 8"
                            BackgroundColor="#0F172A" Stroke="#334155">
                        <Label Text="{Binding QrCurrentUrl}"
                               FontSize="11" TextColor="#38BDF8"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="CharacterWrap" />
                    </Border>
                    <Image Source="{Binding QrCodeImageSource}"
                           WidthRequest="220" HeightRequest="220"
                           HorizontalOptions="Center" />
                    <!-- Copy URL button -->
                    <Button Text="📋 Копировать URL"
                            Command="{Binding CopyQrUrlCommand}"
                            BackgroundColor="#0E7490" TextColor="White"
                            CornerRadius="8" HeightRequest="40" />
                    <Button Text="⭋ Скачать PNG"
                            Command="{Binding DownloadQrCodeCommand}"
                            BackgroundColor="#2563EB" TextColor="White"
                            CornerRadius="8" HeightRequest="40" />
                    <Button Text="✕ Закрыть"
                            Command="{Binding DismissQrPopupCommand}"
                            BackgroundColor="#334155" TextColor="#94A3B8"
                            CornerRadius="8" HeightRequest="40" />
                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>